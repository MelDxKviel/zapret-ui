// ──────────────────────────────────────────────────────────────────────────
//  zapret-ui · design tokens
//  Names map 1:1 to the CSS custom properties in design/styles.css.
//  oklch() values are sampled to sRGB hex (Slint cannot parse oklch).
// ──────────────────────────────────────────────────────────────────────────

export struct AppStatus {
    installed: bool,
    installed_version: string,
    latest_version: string,
    update_available: bool,
    running_mode: string,        // "None" | "UserProcess" | "WindowsService"
    active_strategy: string,
    winws_pid: int,
    service_installed: bool,     // service registered with the SCM (running or stopped)
}

// One parsed log line. Tokenisation (timestamp / level / message split) and
// grep+level filtering happen in Rust because Slint has no substring/contains.
export struct LogLineItem {
    line_no: int,
    timestamp: string,   // leading ISO timestamp, "" if none
    level: string,        // "INFO" | "WARN" | "ERROR" | "" (drives colour)
    message: string,      // remainder of the line
}

export struct StrategyItem {
    id: string,
    display_name: string,
    category: string,
    description: string,
    pretty: string,   // display name without the "(ALT…)" suffix
    alt: string,       // text inside the parentheses, e.g. "ALT2" (empty if none)
}

// One row in the strategy-tester results table. `ok`/`total` are the reachable
// endpoint counts; `latency` is the average latency in ms (0 if nothing passed).
// `rank` is 1-based (0 while still streaming); `is_best` flags the winner.
export struct TestResultItem {
    id: string,
    display_name: string,
    pretty: string,
    alt: string,
    ok: int,
    total: int,
    latency: int,
    rank: int,
    is_best: bool,
}

export global ThemePalette {
    in-out property <bool> is-dark: true;

    // ───────── Accent — electric lime (--accent family) ─────────
    // Shared ink; brighter base used for soft fills in both themes.
    out property <color> accent-ink: #0f1401;            // text on accent fill
    property <color> accent-bright: #bce426;             // oklch(0.86 0.20 122)

    out property <color> accent:         is-dark ? #bce426 : #a3c900;
    out property <color> accent-hover:   is-dark ? #c8f227 : #94b900;
    out property <color> accent-pressed: is-dark ? #a4c900 : #86a800;
    out property <color> accent-soft:    is-dark ? #bce42624 : #bce4262e;   // 0.14 / 0.18
    out property <color> accent-line:    is-dark ? #bce42666 : #a3c90080;   // 0.40 / 0.50

    // ───────── Status semantics ─────────
    out property <color> danger:       #f4514f;          // oklch(0.66 0.20 25)
    out property <color> danger-hover: #de3b3d;          // oklch(0.60 0.20 25)
    out property <color> danger-soft:  #f4514f24;        // /0.14
    out property <color> danger-line:  #f4514f73;        // /0.45
    out property <color> warning:      #fab72a;          // oklch(0.82 0.16 80)
    out property <color> warning-soft: #fab72a24;        // /0.14
    out property <color> info:         #61afda;          // oklch(0.72 0.10 235)

    // ───────── DARK palette ─────────
    property <color> dark-bg:            #0b0c0e;
    property <color> dark-bg-2:          #07080a;
    property <color> dark-surface:       #151618;
    property <color> dark-surface-2:     #1d1e21;
    property <color> dark-surface-hover: #202225;
    property <color> dark-border:        #2a2b2e;
    property <color> dark-border-strong: #3c3d41;
    property <color> dark-divider:       #202225;
    property <color> dark-text:          #f2f3f5;
    property <color> dark-text-2:        #abacb0;
    property <color> dark-text-3:        #727376;
    property <color> dark-text-4:        #4c4d50;
    property <color> dark-scroll-thumb:  #343539;

    // ───────── LIGHT palette ─────────
    property <color> light-bg:            #fbfaf8;
    property <color> light-bg-2:          #f6f5f3;
    property <color> light-surface:       #ffffff;
    property <color> light-surface-2:     #f7f7f4;
    property <color> light-surface-hover: #f2f2ef;
    property <color> light-border:        #e5e4e1;
    property <color> light-border-strong: #d2d1cd;
    property <color> light-divider:       #eae9e6;
    property <color> light-text:          #101115;
    property <color> light-text-2:        #4e5053;
    property <color> light-text-3:        #797a7d;
    property <color> light-text-4:        #9d9ea2;
    property <color> light-scroll-thumb:  #cbcac7;

    // ───────── Active (theme-switched) ─────────
    out property <color> bg:            is-dark ? dark-bg : light-bg;
    out property <color> bg-2:          is-dark ? dark-bg-2 : light-bg-2;
    out property <color> surface:       is-dark ? dark-surface : light-surface;
    out property <color> surface-2:     is-dark ? dark-surface-2 : light-surface-2;
    out property <color> surface-hover: is-dark ? dark-surface-hover : light-surface-hover;
    out property <color> border:        is-dark ? dark-border : light-border;
    out property <color> border-strong: is-dark ? dark-border-strong : light-border-strong;
    out property <color> divider:       is-dark ? dark-divider : light-divider;
    out property <color> text:          is-dark ? dark-text : light-text;
    out property <color> text-2:        is-dark ? dark-text-2 : light-text-2;
    out property <color> text-3:        is-dark ? dark-text-3 : light-text-3;
    out property <color> text-4:        is-dark ? dark-text-4 : light-text-4;
    out property <color> scroll-thumb:  is-dark ? dark-scroll-thumb : light-scroll-thumb;

    // ───────── Logs terminal (theme-switched, near-black both) ─────────
    out property <color> logs-bg:      is-dark ? #030405 : #0d0e11;
    out property <color> logs-fg:      is-dark ? #ccced1 : #e3e4e8;
    out property <color> log-ln:       #545558;
    out property <color> log-ln-border:#1a1a1d;
    out property <color> log-ts:       #707175;
    out property <color> log-path:     #838eae;

    // ───────── Typography ─────────
    out property <string> font-sans: "Geist";
    out property <string> font-mono: "Geist Mono";

    out property <length> fs-10: 10px;
    out property <length> fs-11: 11px;
    out property <length> fs-12: 12px;
    out property <length> fs-13: 13px;
    out property <length> fs-14: 14px;
    out property <length> fs-16: 16px;
    out property <length> fs-18: 18px;
    out property <length> fs-22: 22px;
    out property <length> fs-28: 28px;
    out property <length> fs-40: 40px;

    // ───────── Radii ─────────
    out property <length> r-2: 2px;
    out property <length> r-4: 4px;
    out property <length> r-6: 6px;
    out property <length> r-8: 8px;
    out property <length> r-10: 10px;
    out property <length> r-12: 12px;
    out property <length> r-16: 16px;
    out property <length> r-full: 999px;

    // ───────── Spacing (4px base) ─────────
    out property <length> s-1: 4px;
    out property <length> s-2: 8px;
    out property <length> s-3: 12px;
    out property <length> s-4: 16px;
    out property <length> s-5: 20px;
    out property <length> s-6: 24px;
    out property <length> s-8: 32px;
    out property <length> s-10: 40px;
    out property <length> s-12: 48px;
}
