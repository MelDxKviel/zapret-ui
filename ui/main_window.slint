import { ThemePalette, AppStatus, StrategyItem } from "tokens.slint";
import { HomePage } from "pages/home.slint";
import { StrategiesPage } from "pages/strategies.slint";
import { SettingsPage } from "pages/settings.slint";
import { LogsPage } from "pages/logs.slint";
import { AboutPage } from "pages/about.slint";

export { StrategyItem, AppStatus }

component NavItem inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active;
    callback clicked;

    height: 40px;
    border-radius: 10px;
    background: root.active ? ThemePalette.accent-primary-glow : (ta.has-hover ? ThemePalette.surface-hover : transparent);
    border-width: 1px;
    border-color: root.active ? ThemePalette.accent-primary : transparent;
    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;

        // Wrap the icon so it is vertically centered within the row.
        VerticalLayout {
            alignment: center;
            width: 18px;
            Image {
                source: root.icon;
                width: 18px;
                height: 18px;
                colorize: root.active ? ThemePalette.accent-primary : ThemePalette.text-secondary;
                animate colorize { duration: 120ms; }
            }
        }

        Text {
            text: root.label;
            font-family: ThemePalette.font-family;
            font-size: ThemePalette.font-size-sm;
            font-weight: root.active ? 700 : 500;
            color: root.active ? ThemePalette.accent-primary : ThemePalette.text-secondary;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
}

export component MainWindow inherits Window {
    title: "Zapret UI";
    preferred-width: 1080px;
    preferred-height: 720px;
    min-width: 920px;
    min-height: 600px;
    background: ThemePalette.bg;

    // Flat status properties (set from Rust)
    in-out property <bool> status_installed: false;
    in-out property <string> status_installed_version: "";
    in-out property <string> status_running_mode: "None";
    in-out property <string> status_active_strategy: "";
    in-out property <int> status_winws_pid: 0;

    // Progress / busy state
    in-out property <float> progress: 0.0;
    in-out property <bool> is_busy: false;
    in-out property <bool> has_update: false;
    in-out property <string> latest_version: "";

    // Data lists
    in-out property <[StrategyItem]> strategies: [];
    in-out property <string> selected_category: "All";
    in-out property <string> selected_strategy: "";
    in-out property <string> log_text: "";

    // Settings (UI-local for now)
    in-out property <bool> autostart: false;
    in-out property <bool> autoupdate_check: true;
    in-out property <bool> minimize_to_tray: false;
    in-out property <string> install_dir: "";
    in-out property <string> theme: "dark";

    // Aggregated AppStatus
    property <AppStatus> status: {
        installed: root.status_installed,
        installed_version: root.status_installed_version,
        latest_version: root.latest_version,
        update_available: root.has_update,
        running_mode: root.status_running_mode,
        active_strategy: root.status_active_strategy,
        winws_pid: root.status_winws_pid,
    };

    // Callbacks back to Rust
    callback start_clicked(string);
    callback stop_clicked();
    callback strategy_selected(string);
    callback category_changed(string);
    callback install_clicked();
    callback update_clicked();
    callback set_strategy_as_service(string);
    callback service_remove_clicked();
    callback service_start_clicked();
    callback service_stop_clicked();
    callback open_folder_clicked();
    callback refresh_status_clicked();

    // Internal nav state
    in-out property <string> current_page: "home";

    init => {
        ThemePalette.is-dark = root.theme != "light";
    }

    changed theme => {
        ThemePalette.is-dark = root.theme != "light";
    }

    HorizontalLayout {
        spacing: 0px;

        // SIDEBAR
        Rectangle {
            width: 220px;
            background: ThemePalette.surface;

            VerticalLayout {
                padding-top: 18px;
                padding-bottom: 18px;
                padding-left: 14px;
                padding-right: 14px;
                spacing: 4px;
                alignment: start;

                // Brand
                HorizontalLayout {
                    spacing: 12px;
                    padding-bottom: 22px;

                    Rectangle {
                        width: 38px;
                        height: 38px;
                        border-radius: 10px;
                        background: @linear-gradient(135deg, ThemePalette.accent-primary 0%, ThemePalette.accent-success 100%);

                        Text {
                            text: "Z";
                            color: #ffffff;
                            font-family: ThemePalette.font-family;
                            font-size: 18px;
                            font-weight: 900;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        spacing: 1px;
                        Text {
                            text: "zapret-ui";
                            font-family: ThemePalette.font-family;
                            font-size: ThemePalette.font-size-md;
                            font-weight: 800;
                            color: ThemePalette.text-primary;
                        }
                        Text {
                            text: "DPI bypass control";
                            font-family: ThemePalette.font-family;
                            font-size: ThemePalette.font-size-xs;
                            color: ThemePalette.text-muted;
                        }
                    }
                }

                NavItem {
                    label: "Home";
                    icon: @image-url("../assets/icons/home.svg");
                    active: root.current_page == "home";
                    clicked => { root.current_page = "home"; }
                }
                NavItem {
                    label: "Strategies";
                    icon: @image-url("../assets/icons/strategies.svg");
                    active: root.current_page == "strategies";
                    clicked => { root.current_page = "strategies"; }
                }
                NavItem {
                    label: "Settings";
                    icon: @image-url("../assets/icons/settings.svg");
                    active: root.current_page == "settings";
                    clicked => { root.current_page = "settings"; }
                }
                NavItem {
                    label: "Logs";
                    icon: @image-url("../assets/icons/logs.svg");
                    active: root.current_page == "logs";
                    clicked => { root.current_page = "logs"; }
                }
                NavItem {
                    label: "About";
                    icon: @image-url("../assets/icons/about.svg");
                    active: root.current_page == "about";
                    clicked => { root.current_page = "about"; }
                }

                // Spacer
                Rectangle { background: transparent; }

                // Footer: version + theme toggle
                Rectangle {
                    height: 40px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    background: refresh-ta.has-hover ? ThemePalette.surface-hover : transparent;
                    animate background { duration: 120ms; }

                    refresh-ta := TouchArea {
                        clicked => { root.refresh_status_clicked(); }
                    }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            y: parent.height / 2 - 4px;
                            border-radius: 4px;
                            background: root.status_running_mode == "None" ? ThemePalette.text-muted : ThemePalette.accent-success;
                        }
                        Text {
                            text: "Refresh status";
                            font-family: ThemePalette.font-family;
                            font-size: ThemePalette.font-size-xs;
                            font-weight: 600;
                            color: ThemePalette.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // CONTENT
        Rectangle {
            background: ThemePalette.bg;
            clip: true;

            if root.current_page == "home" : HomePage {
                status: root.status;
                selected_strategy: root.selected_strategy;
                progress: root.progress;
                is_busy: root.is_busy;
                start_clicked => { root.start_clicked(root.selected_strategy); }
                stop_clicked => { root.stop_clicked(); }
                install_clicked => { root.install_clicked(); }
                update_clicked => { root.update_clicked(); }
                open_folder_clicked => { root.open_folder_clicked(); }
                pick_strategy_clicked => { root.current_page = "strategies"; }
                run_as_service_clicked => { root.set_strategy_as_service(root.selected_strategy); }
                service_stop_clicked => { root.service_stop_clicked(); }
                service_remove_clicked => { root.service_remove_clicked(); }
            }

            if root.current_page == "strategies" : StrategiesPage {
                strategies_model: root.strategies;
                active_strategy_id: root.status_active_strategy;
                selected_strategy: root.selected_strategy;
                is_busy: root.is_busy;
                // Selecting a strategy just picks it and returns to Home — it does NOT auto-start.
                strategy_selected(id) => {
                    root.selected_strategy = id;
                    root.current_page = "home";
                }
            }

            if root.current_page == "settings" : SettingsPage {
                autostart <=> root.autostart;
                autoupdate_check <=> root.autoupdate_check;
                install_dir <=> root.install_dir;
                minimize_to_tray <=> root.minimize_to_tray;
                theme <=> root.theme;
                open_folder_clicked => { root.open_folder_clicked(); }
            }

            if root.current_page == "logs" : LogsPage {
                log_text: root.log_text;
                open_folder_clicked => { root.open_folder_clicked(); }
                clear_clicked => { root.log_text = ""; }
            }

            if root.current_page == "about" : AboutPage {
                status: root.status;
            }
        }
    }
}
