// Bundle Geist (sans) + Geist Mono at compile time.
import "assets/fonts/Geist-Regular.ttf";
import "assets/fonts/Geist-Medium.ttf";
import "assets/fonts/Geist-SemiBold.ttf";
import "assets/fonts/Geist-Bold.ttf";
import "assets/fonts/GeistMono-Regular.ttf";
import "assets/fonts/GeistMono-Medium.ttf";

import { ThemePalette, AppStatus, StrategyItem, LogLineItem, TestResultItem } from "tokens.slint";
import { I18n } from "i18n.slint";
import { BrandMark } from "components/brand_mark.slint";
import { StatusDot } from "components/status_dot.slint";
import { HostsDialog } from "components/hosts_dialog.slint";
import { AdminBanner } from "components/admin_banner.slint";
import { HomePage } from "pages/home.slint";
import { StrategiesPage } from "pages/strategies.slint";
import { TesterPage } from "pages/tester.slint";
import { SettingsPage } from "pages/settings.slint";
import { LogsPage } from "pages/logs.slint";
import { AboutPage } from "pages/about.slint";

export { StrategyItem, AppStatus, LogLineItem, TestResultItem, I18n }

// ── Sidebar nav row ──
component NavItem inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active;
    callback clicked;

    height: 32px;
    border-radius: ThemePalette.r-8;
    background: root.active ? ThemePalette.surface : (ta.has-hover ? ThemePalette.surface : transparent);
    animate background { duration: 120ms; }

    // active 2px lime bar at x = -12px
    if root.active : Rectangle {
        x: -12px;
        y: 9px;
        width: 2px;
        height: parent.height - 18px;
        border-radius: ThemePalette.r-2;
        background: ThemePalette.accent;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            width: 16px;
            Image {
                source: root.icon;
                width: 16px;
                height: 16px;
                colorize: root.active ? ThemePalette.accent : ThemePalette.text-2;
                animate colorize { duration: 120ms; }
            }
        }
        Text {
            text: root.label;
            font-family: ThemePalette.font-sans;
            font-size: ThemePalette.fs-13;
            font-weight: root.active ? 600 : 500;
            color: root.active ? ThemePalette.text : ThemePalette.text-2;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }
}

// ── Sidebar theme toggle (sun / moon / system) ──
component ThemeToggleBtn inherits Rectangle {
    in property <image> icon;
    in property <bool> active;
    callback clicked;
    horizontal-stretch: 1;
    height: 26px;
    border-radius: ThemePalette.r-6;
    background: root.active ? ThemePalette.surface-2 : transparent;
    animate background { duration: 120ms; }
    Image {
        source: root.icon;
        width: 13px; height: 13px;
        colorize: root.active ? ThemePalette.text : ThemePalette.text-3;
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

// ── Fade-in wrapper (200ms on page change) ──
component Fade inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;
    property <bool> shown: false;
    opacity: root.shown ? 1.0 : 0.0;
    animate opacity { duration: 200ms; easing: ease-out; }
    init => { root.shown = true; }
    @children
}

export component MainWindow inherits Window {
    title: "zapret-ui";
    icon: root.app_icon;
    preferred-width: 1080px;
    preferred-height: 880px;
    min-width: 920px;
    min-height: 640px;
    background: ThemePalette.bg;

    // Window/taskbar icon (set from Rust).
    in property <image> app_icon;

    // ── Status (set from Rust) ──
    in-out property <bool> status_installed: false;
    in-out property <string> status_installed_version: "";
    in-out property <string> status_running_mode: "None";
    in-out property <string> status_active_strategy: "";
    in-out property <int> status_winws_pid: 0;
    in-out property <bool> status_service_installed: false;
    // Authoritative bypass uptime in seconds (from the OS, via Rust). Re-synced
    // on every status poll; the UI ticks `uptime` locally between polls.
    in-out property <int> status_uptime: 0;

    in-out property <float> progress: 0.0;
    in-out property <bool> is_busy: false;
    // Which bypass transition is in flight: "start" | "stop" | "". Set the instant
    // the user clicks (for immediate spinner feedback) and cleared by Rust when the
    // resulting status/error lands and flips `is_busy` back off.
    in-out property <string> pending_op: "";
    changed is_busy => { if (!root.is_busy) { root.pending_op = ""; } }
    in-out property <bool> has_update: false;
    in-out property <string> latest_version: "";

    // Whether this process is elevated. When false, the admin banner shows and
    // the admin-only actions (Engage, Tester, Windows service) are disabled.
    in-out property <bool> is_admin: true;
    // Windows toast notifications on bypass start/stop (Settings → Application).
    in-out property <bool> notifications: true;

    // ── Data ──
    in-out property <[StrategyItem]> strategies: [];
    in-out property <string> selected_strategy: "";
    in-out property <string> strategies_query: "";
    in-out property <[LogLineItem]> log_lines: [];
    in-out property <string> log_text: "";

    // ── Strategy tester ──
    in-out property <[TestResultItem]> test_results: [];
    in-out property <bool> test_running: false;
    in-out property <int> test_current: 0;
    in-out property <int> test_total: 0;
    in-out property <string> test_current_strategy: "";
    in-out property <string> test_best_id: "";

    // Resolved strategy items for display. `selected_item` is set when the user
    // picks on the Strategies page; `active_item` is resolved by Rust from the
    // running strategy.
    in-out property <StrategyItem> selected_item;
    in-out property <StrategyItem> active_item;

    // ── Settings (UI-local; persisted by Rust where wired) ──
    in-out property <bool> autostart: false;
    in-out property <bool> autoupdate_check: true;
    in-out property <bool> minimize_to_tray: false;
    in-out property <bool> autoengage: false;
    in-out property <bool> compact: false;
    in-out property <string> install_dir: "";
    in-out property <string> theme: "dark";

    // ── DPI bypass tuning (zapret service.bat filters; set from Rust) ──
    in-out property <string> game_filter: "off";   // off | all | tcp | udp
    in-out property <string> ipset_mode: "unknown"; // any | none | loaded | unknown
    in-out property <int> ipset_lines: 0;
    in-out property <bool> ipset_busy: false;
    in-out property <string> ipset_msg: "";
    in-out property <bool> ipset_ok: true;
    in-out property <bool> hosts_busy: false;
    in-out property <string> hosts_msg: "";
    in-out property <bool> hosts_ok: true;
    // Hosts review window (opened when the system hosts file is out of date).
    in-out property <bool> hosts_modal_open: false;
    in-out property <string> hosts_content: "";
    in-out property <string> hosts_path: "";
    in-out property <string> hosts_dir: "";

    // ── Aggregated status ──
    property <AppStatus> status: {
        installed: root.status_installed,
        installed_version: root.status_installed_version,
        latest_version: root.latest_version,
        update_available: root.has_update,
        running_mode: root.status_running_mode,
        active_strategy: root.status_active_strategy,
        winws_pid: root.status_winws_pid,
        service_installed: root.status_service_installed,
    };

    property <bool> running: root.status_running_mode != "None";
    property <StrategyItem> chosen_item: root.running && root.active_item.id != "" ? root.active_item : root.selected_item;
    property <bool> has_strategy: root.chosen_item.id != "";

    // ── Live bypass uptime ──
    // Owned by the window (not the page) so it survives page navigation. Seeded
    // from the OS-reported `status_uptime` on every poll, ticked locally each second.
    in-out property <int> uptime: 0;
    changed status_uptime => { root.uptime = root.status_uptime; }
    changed running => { if (!root.running) { root.uptime = 0; } }
    Timer {
        interval: 1s;
        running: root.running;
        triggered => { root.uptime += 1; }
    }

    // ── Callbacks to Rust ──
    callback start_clicked(string);
    callback stop_clicked();
    callback strategy_selected(string);
    callback install_clicked();
    callback update_clicked();
    callback service_install_clicked(string);
    callback service_remove_clicked();
    callback service_start_clicked();
    callback service_stop_clicked();
    callback open_folder_clicked();
    callback refresh_status_clicked();
    callback strategies_search(string);
    callback test_start_clicked();
    callback test_cancel_clicked();
    callback test_use_strategy(string);
    callback toggle_favorite(string);
    callback logs_query_changed(string, string);
    callback logs_clear_clicked();
    callback open_log_file_clicked();
    callback open_url_clicked(string);
    callback set_language(string);
    callback set_game_filter(string);
    callback set_ipset_mode(string);
    callback update_ipset_clicked();
    callback update_hosts_clicked();
    callback copy_to_clipboard(string);
    callback set_notifications(bool);
    callback restart_as_admin();

    in-out property <string> current_page: "home";

    init => { ThemePalette.is-dark = root.theme != "light"; }
    changed theme => { ThemePalette.is-dark = root.theme != "light"; }

    HorizontalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // ════════ SIDEBAR ════════
        Rectangle {
            width: 232px;
            background: ThemePalette.bg-2;
            Rectangle { x: parent.width - 1px; width: 1px; background: ThemePalette.border; }

            VerticalLayout {

                // brand
                HorizontalLayout {
                    vertical-stretch: 0;
                    padding-left: 18px;
                    padding-right: 18px;
                    padding-top: 20px;
                    padding-bottom: 18px;
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        BrandMark { size: 22px; }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        alignment: center;
                        Text {
                            text: "zapret-ui";
                            font-family: ThemePalette.font-sans;
                            font-size: ThemePalette.fs-14;
                            font-weight: 700;
                            color: ThemePalette.text;
                        }
                        Text {
                            text: "DPI BYPASS";
                            font-family: ThemePalette.font-mono;
                            font-size: ThemePalette.fs-10;
                            color: ThemePalette.text-3;
                            letter-spacing: 1.2px;
                        }
                    }
                    Rectangle { }
                }

                // workspace section
                VerticalLayout {
                    vertical-stretch: 0;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 1px;
                    Text {
                        text: I18n.t(I18n.lang, "nav.workspace");
                        font-family: ThemePalette.font-mono;
                        font-size: ThemePalette.fs-10;
                        color: ThemePalette.text-4;
                        letter-spacing: 1.4px;
                        // padding via a wrapper
                    }
                    Rectangle { height: 6px; }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.dashboard");
                        icon: @image-url("../assets/icons/home.svg");
                        active: root.current_page == "home";
                        clicked => { root.current_page = "home"; }
                    }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.strategies");
                        icon: @image-url("../assets/icons/strategies.svg");
                        active: root.current_page == "strategies";
                        clicked => { root.current_page = "strategies"; }
                    }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.tester");
                        icon: @image-url("../assets/icons/rocket.svg");
                        active: root.current_page == "tester";
                        clicked => { root.current_page = "tester"; }
                    }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.logs");
                        icon: @image-url("../assets/icons/logs.svg");
                        active: root.current_page == "logs";
                        clicked => { root.current_page = "logs"; }
                    }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.settings");
                        icon: @image-url("../assets/icons/settings.svg");
                        active: root.current_page == "settings";
                        clicked => { root.current_page = "settings"; }
                    }
                    NavItem {
                        label: I18n.t(I18n.lang, "nav.about");
                        icon: @image-url("../assets/icons/about.svg");
                        active: root.current_page == "about";
                        clicked => { root.current_page = "about"; }
                    }
                }

                Rectangle { vertical-stretch: 1; } // spacer pushes the footer to the bottom

                // footer
                VerticalLayout {
                    vertical-stretch: 0;
                    padding: 12px;
                    spacing: 8px;
                    Rectangle { height: 1px; background: ThemePalette.border; }
                    Rectangle { height: 4px; }

                    // status pill (click → refresh)
                    Rectangle {
                        height: 40px;
                        border-radius: ThemePalette.r-8;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: pill-ta.has-hover ? ThemePalette.surface-hover : ThemePalette.surface;
                        animate background { duration: 120ms; }
                        pill-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.current_page = "home";
                                root.refresh_status_clicked();
                            }
                        }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            VerticalLayout {
                                alignment: center;
                                StatusDot {
                                    variant: root.running ? "active" : (root.status_installed ? "idle" : "danger");
                                }
                            }
                            Text {
                                text: root.running
                                        ? (root.status_running_mode == "WindowsService" ? I18n.t(I18n.lang, "sidebar.status_service_running") : I18n.t(I18n.lang, "sidebar.status_bypass_active"))
                                        : (root.status_installed ? I18n.t(I18n.lang, "sidebar.status_idle") : I18n.t(I18n.lang, "sidebar.status_not_installed"));
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                font-weight: 500;
                                color: ThemePalette.text-2;
                                vertical-alignment: center;
                            }
                            Rectangle { }
                            if root.running && root.active_item.id != "" : Text {
                                text: root.active_item.alt != "" ? root.active_item.alt : root.active_item.pretty;
                                font-family: ThemePalette.font-mono;
                                font-size: ThemePalette.fs-10;
                                color: ThemePalette.text-3;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // theme toggle
                    Rectangle {
                        height: 32px;
                        border-radius: ThemePalette.r-8;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        background: ThemePalette.surface;
                        HorizontalLayout {
                            padding: 2px;
                            spacing: 2px;
                            // Order matches the Settings → Appearance segmented control.
                            ThemeToggleBtn {
                                icon: @image-url("../assets/icons/moon.svg");
                                active: root.theme == "dark";
                                clicked => { root.theme = "dark"; }
                            }
                            ThemeToggleBtn {
                                icon: @image-url("../assets/icons/sun.svg");
                                active: root.theme == "light";
                                clicked => { root.theme = "light"; }
                            }
                            ThemeToggleBtn {
                                icon: @image-url("../assets/icons/system.svg");
                                active: root.theme == "system";
                                clicked => { root.theme = "system"; }
                            }
                        }
                    }
                }
            }
        }

        // ════════ CONTENT ════════
        Rectangle {
            background: ThemePalette.bg;
            clip: true;

            VerticalLayout {
                // Admin-rights warning bar (only when running unelevated).
                if !root.is_admin : AdminBanner {
                    restart_clicked => { root.restart_as_admin(); }
                }

                // page stack
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;

            if root.current_page == "home" : Fade {
                HomePage {
                    width: 100%;
                    height: 100%;
                    status: root.status;
                    chosen_item: root.chosen_item;
                    has_strategy: root.has_strategy;
                    is_busy: root.is_busy;
                    pending_op: root.pending_op;
                    is_admin: root.is_admin;
                    strategy_count: root.strategies.length;
                    uptime: root.uptime;
                    game_filter <=> root.game_filter;
                    game_filter_changed(v) => { root.set_game_filter(v); }
                    // Mark the transition + lock the UI the instant it's clicked; the
                    // backend round-trip (and the spinner) ends when Status arrives.
                    start_clicked => { root.pending_op = "start"; root.is_busy = true; root.start_clicked(root.chosen_item.id); }
                    stop_clicked => { root.pending_op = "stop"; root.is_busy = true; root.stop_clicked(); }
                    install_clicked => { root.install_clicked(); }
                    update_clicked => { root.update_clicked(); }
                    open_folder_clicked => { root.open_folder_clicked(); }
                    pick_strategy_clicked => { root.current_page = "strategies"; }
                    refresh_clicked => { root.refresh_status_clicked(); }
                    service_install_clicked => { root.service_install_clicked(root.chosen_item.id); }
                    service_start_clicked => { root.pending_op = "start"; root.is_busy = true; root.service_start_clicked(); }
                    service_stop_clicked => { root.pending_op = "stop"; root.is_busy = true; root.service_stop_clicked(); }
                    service_remove_clicked => { root.service_remove_clicked(); }
                }
            }

            if root.current_page == "strategies" : Fade {
                StrategiesPage {
                    width: 100%;
                    height: 100%;
                    strategies_model: root.strategies;
                    active_strategy_id: root.status_active_strategy;
                    selected_strategy: root.selected_item.id;
                    is_busy: root.is_busy;
                    query <=> root.strategies_query;
                    search_changed(q) => { root.strategies_search(q); }
                    picked(item) => {
                        root.selected_item = item;
                        root.selected_strategy = item.id;
                        root.strategy_selected(item.id);
                        root.current_page = "home";
                    }
                    toggle_favorite(id) => { root.toggle_favorite(id); }
                }
            }

            if root.current_page == "tester" : Fade {
                TesterPage {
                    width: 100%;
                    height: 100%;
                    results: root.test_results;
                    is_admin: root.is_admin;
                    running: root.test_running;
                    current: root.test_current;
                    total: root.test_total;
                    current_strategy: root.test_current_strategy;
                    best_id: root.test_best_id;
                    selected_strategy: root.selected_item.id;
                    installed: root.status_installed;
                    strategy_count: root.strategies.length;
                    start_clicked => { root.test_start_clicked(); }
                    cancel_clicked => { root.test_cancel_clicked(); }
                    use_strategy(id) => { root.test_use_strategy(id); }
                    toggle_favorite(id) => { root.toggle_favorite(id); }
                }
            }

            if root.current_page == "settings" : Fade {
                SettingsPage {
                    width: 100%;
                    height: 100%;
                    autostart <=> root.autostart;
                    autoupdate_check <=> root.autoupdate_check;
                    minimize_to_tray <=> root.minimize_to_tray;
                    notifications <=> root.notifications;
                    autoengage <=> root.autoengage;
                    compact <=> root.compact;
                    install_dir <=> root.install_dir;
                    theme <=> root.theme;
                    installed: root.status_installed;
                    game_filter <=> root.game_filter;
                    ipset_mode <=> root.ipset_mode;
                    ipset_lines: root.ipset_lines;
                    ipset_busy: root.ipset_busy;
                    ipset_msg: root.ipset_msg;
                    ipset_ok: root.ipset_ok;
                    hosts_busy: root.hosts_busy;
                    hosts_msg: root.hosts_msg;
                    hosts_ok: root.hosts_ok;
                    open_folder_clicked => { root.open_folder_clicked(); }
                    game_filter_changed(v) => { root.set_game_filter(v); }
                    ipset_mode_changed(v) => { root.set_ipset_mode(v); }
                    update_ipset_clicked => { root.update_ipset_clicked(); }
                    update_hosts_clicked => { root.update_hosts_clicked(); }
                    language_changed(v) => { root.set_language(v); }
                    notifications_changed(v) => { root.set_notifications(v); }
                }
            }

            if root.current_page == "logs" : Fade {
                LogsPage {
                    width: 100%;
                    height: 100%;
                    log_lines: root.log_lines;
                    log_text: root.log_text;
                    open_file_clicked => { root.open_log_file_clicked(); }
                    clear_clicked => { root.logs_clear_clicked(); }
                    query_changed(g, l) => { root.logs_query_changed(g, l); }
                }
            }

            if root.current_page == "about" : Fade {
                AboutPage {
                    width: 100%;
                    height: 100%;
                    status: root.status;
                    open_url(u) => { root.open_url_clicked(u); }
                }
            }
                }
            }
        }
    }

    // ── Hosts review modal (overlays everything when open) ──
    HostsDialog {
        open: root.hosts_modal_open;
        content: root.hosts_content;
        hosts_path: root.hosts_path;
        copy_clicked => { root.copy_to_clipboard(root.hosts_content); }
        open_folder_clicked => { root.open_url_clicked(root.hosts_dir); }
        close_clicked => { root.hosts_modal_open = false; }
    }
}
