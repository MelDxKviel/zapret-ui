import { ThemePalette } from "../tokens.slint";

// .switch — 36×20 track, 16×16 thumb, lime fill when on, 160ms ease-in-out.
export component AppSwitch inherits Rectangle {
    in-out property <bool> checked;
    in property <bool> enabled: true;

    callback toggled(bool);

    width: 36px;
    height: 20px;
    border-radius: ThemePalette.r-full;
    background: root.checked ? ThemePalette.accent : ThemePalette.border-strong;
    opacity: root.enabled ? 1.0 : 0.45;
    animate background { duration: 160ms; easing: ease-in-out; }

    Rectangle {
        x: root.checked ? 18px : 2px;
        y: 2px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: root.checked ? ThemePalette.accent-ink : ThemePalette.surface;
        animate x { duration: 160ms; easing: ease-in-out; }
        animate background { duration: 160ms; easing: ease-in-out; }
    }

    TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}
