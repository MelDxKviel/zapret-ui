import { ThemePalette } from "../tokens.slint";
import { Icon } from "icon.slint";

// .btn — variants: default | primary | danger | ghost. Sizes: sm | base | lg.
// Icon slot on the left. Disabled renders at 0.45 opacity and ignores input.
export component AppButton inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <string> variant: "default"; // default | primary | danger | ghost
    in property <string> size: "base";        // sm | base | lg
    in property <bool> enabled: true;
    in property <length> icon-size: 14px;

    callback clicked;

    property <bool> is-primary: root.variant == "primary";
    property <bool> is-danger: root.variant == "danger";
    property <bool> is-ghost: root.variant == "ghost";
    property <bool> hovered: ta.has-hover && root.enabled;

    property <length> h: root.size == "sm" ? 26px : root.size == "lg" ? 40px : 32px;
    property <length> pad: root.size == "sm" ? 10px : root.size == "lg" ? 18px : 14px;
    property <length> fs: root.size == "sm" ? ThemePalette.fs-12 : root.size == "lg" ? ThemePalette.fs-14 : ThemePalette.fs-13;

    // Foreground (text + icon) colour.
    property <color> fg:
        root.is-primary ? ThemePalette.accent-ink :
        root.is-danger  ? ThemePalette.danger :
        root.is-ghost   ? (root.hovered ? ThemePalette.text : ThemePalette.text-2) :
        ThemePalette.text;

    height: root.h;
    horizontal-stretch: 0;
    width: lay.preferred-width;
    border-radius: root.size == "sm" ? ThemePalette.r-6 : root.size == "lg" ? ThemePalette.r-10 : ThemePalette.r-8;
    border-width: root.is-ghost ? 0px : 1px;
    opacity: root.enabled ? 1.0 : 0.45;

    background:
        root.is-primary ? (root.hovered ? ThemePalette.accent-hover : ThemePalette.accent) :
        root.is-danger  ? (root.hovered ? ThemePalette.danger-soft : transparent) :
        root.is-ghost   ? (root.hovered ? ThemePalette.surface : transparent) :
        (root.hovered ? ThemePalette.surface-hover : ThemePalette.surface);

    border-color:
        root.is-primary ? (root.hovered ? ThemePalette.accent-hover : ThemePalette.accent) :
        root.is-danger  ? (root.hovered ? ThemePalette.danger : ThemePalette.danger-line) :
        (root.hovered ? ThemePalette.border-strong : ThemePalette.border);

    animate background, border-color { duration: 120ms; easing: ease-out; }

    lay := HorizontalLayout {
        alignment: center;
        spacing: 8px;
        padding-left: root.pad;
        padding-right: root.pad;

        if root.icon.width > 0 : Icon {
            source: root.icon;
            size: root.icon-size;
            tint: root.fg;
        }

        if root.text != "" : Text {
            text: root.text;
            font-family: ThemePalette.font-sans;
            font-size: root.fs;
            font-weight: 500;
            color: root.fg;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }
}
