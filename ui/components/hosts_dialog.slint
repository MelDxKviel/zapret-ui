import { ThemePalette } from "../tokens.slint";
import { AppButton } from "button.slint";
import { Icon } from "icon.slint";
import { TextEdit } from "std-widgets.slint";

// Modal overlay shown when the system hosts file is out of date. Presents the
// repository's hosts content in a read-only monospace viewer with a one-click
// "Copy all" so the user can paste it into their (admin-owned) hosts file.
export component HostsDialog inherits Rectangle {
    in property <bool> open;
    in property <string> content;
    in property <string> hosts_path;

    callback copy_clicked();
    callback open_folder_clicked();
    callback close_clicked();

    // Transient "Copied!" affordance on the copy button.
    property <bool> copied: false;
    changed open => { if (root.open) { root.copied = false; } }

    visible: root.open;
    width: 100%;
    height: 100%;
    // Dim scrim; clicking it dismisses the dialog.
    background: #00000099;
    scrim := TouchArea {
        clicked => { root.close_clicked(); }
    }

    // ── Centered panel ──
    Rectangle {
        width: min(parent.width - 96px, 760px);
        height: min(parent.height - 96px, 640px);
        background: ThemePalette.surface;
        border-width: 1px;
        border-color: ThemePalette.border;
        border-radius: ThemePalette.r-16;
        drop-shadow-blur: 48px;
        drop-shadow-color: #00000099;
        clip: true;

        // Swallow clicks inside the panel so they don't reach the scrim.
        TouchArea { }

        VerticalLayout {
            // ── header ──
            Rectangle {
                height: 66px;
                background: ThemePalette.bg-2;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 14px;
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        spacing: 3px;
                        Text {
                            text: "Update hosts file";
                            font-family: ThemePalette.font-sans;
                            font-size: ThemePalette.fs-16;
                            font-weight: 600;
                            color: ThemePalette.text;
                        }
                        Text {
                            text: "Your hosts file is out of date. Copy these entries into it (editing it needs admin rights).";
                            font-family: ThemePalette.font-sans;
                            font-size: ThemePalette.fs-12;
                            color: ThemePalette.text-3;
                            wrap: word-wrap;
                        }
                    }
                    Rectangle { }
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 30px;
                            height: 30px;
                            border-radius: ThemePalette.r-8;
                            background: close-ta.has-hover ? ThemePalette.surface-hover : transparent;
                            animate background { duration: 120ms; }
                            Image {
                                source: @image-url("../../assets/icons/close.svg");
                                width: 15px;
                                height: 15px;
                                colorize: close-ta.has-hover ? ThemePalette.text : ThemePalette.text-3;
                                animate colorize { duration: 120ms; }
                            }
                            close-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.close_clicked(); }
                            }
                        }
                    }
                }
                Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
            }

            // ── path chip ──
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                padding-bottom: 4px;
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    Icon {
                        source: @image-url("../../assets/icons/folder.svg");
                        size: 13px;
                        tint: ThemePalette.text-4;
                    }
                }
                Text {
                    text: root.hosts_path;
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-11;
                    color: ThemePalette.text-3;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ── content viewer ──
            Rectangle {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                VerticalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 8px;
                    padding-bottom: 16px;
                    editor := TextEdit {
                        read-only: true;
                        text: root.content;
                        font-family: ThemePalette.font-mono;
                        font-size: ThemePalette.fs-12;
                        wrap: no-wrap;
                    }
                }
            }

            // ── footer ──
            Rectangle {
                height: 64px;
                background: ThemePalette.bg-2;
                Rectangle { y: 0; height: 1px; background: ThemePalette.divider; }
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 8px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        AppButton {
                            text: root.copied ? "Copied!" : "Copy all";
                            variant: "primary";
                            icon: root.copied
                                ? @image-url("../../assets/icons/check.svg")
                                : @image-url("../../assets/icons/copy.svg");
                            clicked => {
                                root.copy_clicked();
                                root.copied = true;
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        AppButton {
                            text: "Open hosts folder";
                            icon: @image-url("../../assets/icons/folder.svg");
                            clicked => { root.open_folder_clicked(); }
                        }
                    }
                    Rectangle { }
                    VerticalLayout {
                        alignment: center;
                        AppButton {
                            text: "Close";
                            variant: "ghost";
                            clicked => { root.close_clicked(); }
                        }
                    }
                }
            }
        }
    }
}
