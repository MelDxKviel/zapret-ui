import { ThemePalette, AppStatus, StrategyItem } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { AppButton } from "../components/button.slint";
import { StatusDot } from "../components/status_dot.slint";
import { Icon } from "../components/icon.slint";
import { Spinner } from "../components/spinner.slint";
import { Segmented } from "../components/segmented.slint";
import { ScrollView } from "std-widgets.slint";

// ── Windows-service card: renders ONE of three states (absent / stopped /
//    running) — see DESIGN.md "Service card — state machine".
component ServiceCard inherits Rectangle {
    in property <AppStatus> status;
    in property <bool> is_busy;
    // "start" | "stop" | "" — which bypass transition is in flight (for the
    // spinner on the matching button).
    in property <string> pending_op;
    in property <bool> has_strategy;
    in property <bool> is_admin;
    in property <StrategyItem> chosen_item;

    callback install_clicked();
    callback start_clicked();
    callback stop_clicked();
    callback remove_clicked();

    property <bool> svc-installed: root.status.service_installed;
    property <bool> svc-running: root.svc-installed && root.status.running_mode == "WindowsService";
    property <string> state: !root.svc-installed ? "absent" : (root.svc-running ? "running" : "stopped");

    background: ThemePalette.surface;
    border-width: 1px;
    border-color: ThemePalette.border;
    border-radius: ThemePalette.r-12;
    clip: true;
    vertical-stretch: 0;

    VerticalLayout {
        alignment: start;

        // card-head
        Rectangle {
            height: 48px;
            background: transparent;
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                Text {
                    text: I18n.t(I18n.lang, "service.header");
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-12;
                    font-weight: 600;
                    color: ThemePalette.text-3;
                    letter-spacing: 0.6px;
                    vertical-alignment: center;
                }
                Rectangle { }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    VerticalLayout {
                        alignment: center;
                        StatusDot {
                            variant: root.state == "running" ? "active" : root.state == "stopped" ? "warn" : "idle";
                        }
                    }
                    Text {
                        text: root.state == "running" ? I18n.t(I18n.lang, "service.installed_running")
                            : root.state == "stopped" ? I18n.t(I18n.lang, "service.installed_stopped")
                            : I18n.t(I18n.lang, "service.not_configured");
                        font-family: ThemePalette.font-mono;
                        font-size: ThemePalette.fs-12;
                        color: ThemePalette.text-2;
                        vertical-alignment: center;
                    }
                }
            }
            // bottom divider
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: ThemePalette.divider;
            }
        }

        // card-body
        VerticalLayout {
            padding: 18px;
            spacing: 14px;
            alignment: start;

            if root.state == "absent" : VerticalLayout {
                spacing: 14px;
                Text {
                    text: I18n.t(I18n.lang, "service.absent_desc");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    color: ThemePalette.text-2;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: start;
                    AppButton {
                        text: I18n.t(I18n.lang, "service.install_btn");
                        variant: "primary";
                        // Not gated on is_admin: the backend requests UAC on demand
                        // for service operations (one-shot elevated helper).
                        icon: @image-url("../../assets/icons/service.svg");
                        enabled: !root.is_busy && root.has_strategy && root.status.installed;
                        clicked => { root.install_clicked(); }
                    }
                }
                if !root.has_strategy : Text {
                    text: I18n.t(I18n.lang, "service.pick_first");
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-11;
                    color: ThemePalette.text-3;
                }
            }

            if root.state == "stopped" : VerticalLayout {
                spacing: 14px;
                Text {
                    text: I18n.t(I18n.lang, "service.stopped_desc_a") + root.chosen_item.id + I18n.t(I18n.lang, "service.stopped_desc_b");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    color: ThemePalette.text-2;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    AppButton {
                        text: root.pending_op == "start" ? I18n.t(I18n.lang, "service.starting") : I18n.t(I18n.lang, "service.start_btn");
                        variant: "primary";
                        icon: @image-url("../../assets/icons/play.svg");
                        enabled: !root.is_busy;
                        busy: root.pending_op == "start";
                        clicked => { root.start_clicked(); }
                    }
                    AppButton {
                        text: I18n.t(I18n.lang, "service.uninstall_btn");
                        variant: "danger";
                        size: "sm";
                        icon: @image-url("../../assets/icons/trash.svg");
                        enabled: !root.is_busy;
                        clicked => { root.remove_clicked(); }
                    }
                }
            }

            if root.state == "running" : VerticalLayout {
                spacing: 14px;
                Text {
                    text: I18n.t(I18n.lang, "service.running_desc_a") + root.chosen_item.id + I18n.t(I18n.lang, "service.running_desc_b");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    color: ThemePalette.text-2;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    AppButton {
                        text: root.pending_op == "stop" ? I18n.t(I18n.lang, "service.stopping") : I18n.t(I18n.lang, "service.stop_btn");
                        variant: "default";
                        icon: @image-url("../../assets/icons/stop.svg");
                        enabled: !root.is_busy;
                        busy: root.pending_op == "stop";
                        clicked => { root.stop_clicked(); }
                    }
                    AppButton {
                        text: I18n.t(I18n.lang, "service.uninstall_btn");
                        variant: "danger";
                        size: "sm";
                        icon: @image-url("../../assets/icons/trash.svg");
                        enabled: !root.is_busy;
                        clicked => { root.remove_clicked(); }
                    }
                }
            }
        }
    }
}

// ── A single stat cell in the strip ──
component Stat inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value-color: ThemePalette.text;
    in property <bool> last: false;
    horizontal-stretch: 1;
    background: transparent;
    VerticalLayout {
        padding: 14px;
        spacing: 6px;
        alignment: center;
        Text {
            text: root.label;
            font-family: ThemePalette.font-mono;
            font-size: ThemePalette.fs-10;
            color: ThemePalette.text-4;
            letter-spacing: 1px;
        }
        Text {
            text: root.value;
            font-family: ThemePalette.font-mono;
            font-size: ThemePalette.fs-14;
            font-weight: 500;
            color: root.value-color;
        }
    }
    if !root.last : Rectangle {
        x: parent.width - 1px;
        width: 1px;
        background: ThemePalette.divider;
    }
}

// ── An install/update/folder action tile ──
component ActionTile inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> sub;
    in property <bool> highlight: false;
    in property <bool> enabled: true;
    callback clicked();
    horizontal-stretch: 1;
    height: 60px;
    border-radius: ThemePalette.r-10;
    border-width: 1px;
    border-color: root.highlight ? ThemePalette.accent-line : ThemePalette.border;
    background: root.highlight
        ? @linear-gradient(180deg, ThemePalette.accent-soft 0%, transparent 100%)
        : (ta.has-hover ? ThemePalette.surface-hover : ThemePalette.surface);
    opacity: root.enabled ? 1.0 : 0.45;
    animate background, border-color { duration: 120ms; }

    HorizontalLayout {
        padding: 14px;
        spacing: 12px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: ThemePalette.r-8;
                background: root.highlight ? ThemePalette.accent : ThemePalette.surface-2;
                Image {
                    source: root.icon;
                    width: 16px;
                    height: 16px;
                    colorize: root.highlight ? ThemePalette.accent-ink : ThemePalette.text-2;
                }
            }
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.title;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-13;
                font-weight: 600;
                color: ThemePalette.text;
                overflow: elide;
            }
            Text {
                text: root.sub;
                font-family: ThemePalette.font-mono;
                font-size: ThemePalette.fs-11;
                color: ThemePalette.text-3;
                overflow: elide;
            }
        }
    }
    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }
}

// dl-row for the strategy-detail card
component DetailRow inherits Rectangle {
    in property <string> key;
    in property <string> value;
    in property <bool> last: false;
    height: 33px;
    HorizontalLayout {
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 12px;
        // Key keeps its natural width; the value takes the rest and elides,
        // so a long value can never overrun the key label.
        Text {
            text: root.key;
            horizontal-stretch: 0;
            font-family: ThemePalette.font-mono;
            font-size: ThemePalette.fs-11;
            color: ThemePalette.text-4;
            letter-spacing: 0.8px;
            vertical-alignment: center;
        }
        Text {
            text: root.value;
            horizontal-stretch: 1;
            font-family: ThemePalette.font-mono;
            font-size: ThemePalette.fs-12;
            color: ThemePalette.text;
            vertical-alignment: center;
            horizontal-alignment: right;
            overflow: elide;
        }
    }
    if !root.last : Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: ThemePalette.divider;
    }
}

// ── A titled card wrapping one DPI-filter control (game filter / ipset) ──
component FilterCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> hint;
    horizontal-stretch: 1;
    background: ThemePalette.surface;
    border-width: 1px;
    border-color: ThemePalette.border;
    border-radius: ThemePalette.r-12;
    clip: true;
    vertical-stretch: 0;
    VerticalLayout {
        padding: 16px;
        spacing: 14px;
        alignment: start;
        // header: icon badge + title / hint
        HorizontalLayout {
            spacing: 12px;
            VerticalLayout {
                alignment: start;
                Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: ThemePalette.r-8;
                    background: ThemePalette.surface-2;
                    Image {
                        source: root.icon;
                        width: 16px;
                        height: 16px;
                        colorize: ThemePalette.text-2;
                    }
                }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                alignment: center;
                Text {
                    text: root.title;
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    font-weight: 600;
                    color: ThemePalette.text;
                }
                Text {
                    text: root.hint;
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-12;
                    color: ThemePalette.text-3;
                    wrap: word-wrap;
                }
            }
        }
        @children
    }
}

export component HomePage inherits Rectangle {
    in property <AppStatus> status;
    in property <StrategyItem> chosen_item;
    in property <bool> has_strategy;
    in property <bool> is_busy;
    // "start" | "stop" | "" — the bypass transition currently in flight, used to
    // drive the spinner + transitional label on the power button.
    in property <string> pending_op;
    in property <bool> is_admin;
    in property <int> strategy_count;
    // This app's version (from Cargo, via Rust) — shown in the stats strip.
    in property <string> app_version;
    // Live bypass uptime in seconds — owned by MainWindow so it persists across
    // page navigation and reflects the real bypass session.
    in property <int> uptime;
    // Game filter mode (off | all | tcp | udp), shared with the Settings page.
    in-out property <string> game_filter;
    // IPSet filter (any | none | loaded | unknown) + its update affordance, also
    // shared with the Settings page.
    in-out property <string> ipset_mode;
    in property <int> ipset_lines;
    // Age of ipset-all.txt in days (-1 = absent/unknown); when high we nudge the
    // user to refresh the blocked-IP list.
    in property <int> ipset_age_days: -1;
    in property <bool> ipset_busy;
    in property <string> ipset_msg;
    in property <bool> ipset_ok: true;

    callback game_filter_changed(string);
    callback ipset_mode_changed(string);
    callback update_ipset_clicked();
    callback start_clicked();
    callback stop_clicked();
    callback install_clicked();
    callback update_clicked();
    callback open_folder_clicked();
    callback pick_strategy_clicked();
    callback refresh_clicked();
    callback service_install_clicked();
    callback service_start_clicked();
    callback service_stop_clicked();
    callback service_remove_clicked();

    background: transparent;

    property <bool> running: root.status.running_mode != "None";
    property <bool> installed: root.status.installed;
    property <bool> has-update: root.status.update_available;

    property <string> state-label: !root.installed ? I18n.t(I18n.lang, "home.state_not_installed")
        : (root.running && root.status.running_mode == "WindowsService") ? I18n.t(I18n.lang, "home.state_service_active")
        : root.running ? I18n.t(I18n.lang, "home.state_active")
        : I18n.t(I18n.lang, "home.state_stopped");
    property <color> state-color: !root.installed ? ThemePalette.danger
        : root.running ? ThemePalette.accent : ThemePalette.text;
    property <string> dot-variant: !root.installed ? "danger" : root.running ? "active" : "idle";

    // The blocked-IP list is in active use (loaded) and old enough to be worth
    // refreshing — surfaces the warning-tinted reminder in the IPSet card.
    property <bool> ipset-stale: root.installed && root.ipset_mode == "loaded" && root.ipset_age_days >= 14;

    property <bool> can-engage: root.installed && !root.is_busy && root.has_strategy && root.is_admin;
    // A start/stop is mid-flight: power button shows a spinner + label and locks.
    property <bool> transitioning: root.pending_op == "start" || root.pending_op == "stop";

    // Uptime is supplied by MainWindow (see `uptime` property above).
    property <int> up-h: floor(root.uptime / 3600);
    property <int> up-m: floor((root.uptime - root.up-h * 3600) / 60);
    property <int> up-s: root.uptime - root.up-h * 3600 - root.up-m * 60;
    pure function pad2(n: int) -> string { return n < 10 ? "0\{n}" : "\{n}"; }

    sv := ScrollView {
        viewport-width: sv.visible-width;
        HorizontalLayout {
            // left-aligned content column capped at 980px (matches .main-inner)
            VerticalLayout {
                horizontal-stretch: 0;
                width: min(sv.visible-width - 64px, 980px);
                padding-left: 32px;
                padding-top: 28px;
                padding-right: 32px;
                padding-bottom: 60px;
                spacing: 0px;
                alignment: start;

                // ── page-head ──
                HorizontalLayout {
                    padding-bottom: 20px;
                    spacing: 16px;
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 2px;
                        alignment: end;
                        Text {
                            text: I18n.t(I18n.lang, "home.title");
                            font-family: ThemePalette.font-sans;
                            font-size: ThemePalette.fs-22;
                            font-weight: 600;
                            color: ThemePalette.text;
                        }
                        Text {
                            text: I18n.t(I18n.lang, "home.subtitle");
                            font-family: ThemePalette.font-sans;
                            font-size: ThemePalette.fs-13;
                            color: ThemePalette.text-3;
                            wrap: word-wrap;
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 0;
                        alignment: end;
                        AppButton {
                            text: I18n.t(I18n.lang, "common.refresh");
                            variant: "ghost";
                            size: "sm";
                            icon: @image-url("../../assets/icons/refresh.svg");
                            clicked => { root.refresh_clicked(); }
                        }
                    }
                }

                // ── HERO ──
                Rectangle {
                    height: hero-content.preferred-height;
                    background: @linear-gradient(180deg, ThemePalette.surface 0%, ThemePalette.bg-2 100%);
                    border-width: 1px;
                    border-color: ThemePalette.border;
                    border-radius: ThemePalette.r-16;
                    clip: true;

                    // accent glow (radial fallback → top linear tint)
                    Rectangle {
                        y: 0;
                        height: 50%;
                        background: @linear-gradient(180deg, ThemePalette.accent-soft 0%, transparent 100%);
                    }

                    hero-content := VerticalLayout {
                        padding: 28px;
                        spacing: 28px;

                        // hero-top
                        HorizontalLayout {
                            VerticalLayout {
                                spacing: 6px;
                                alignment: start;
                                Text {
                                    text: I18n.t(I18n.lang, "home.bypass_status");
                                    font-family: ThemePalette.font-mono;
                                    font-size: ThemePalette.fs-10;
                                    color: ThemePalette.text-4;
                                    letter-spacing: 1.4px;
                                }
                                HorizontalLayout {
                                    spacing: 10px;
                                    alignment: start;
                                    VerticalLayout {
                                        alignment: center;
                                        StatusDot { variant: root.dot-variant; dot-size: 10px; }
                                    }
                                    Text {
                                        text: root.state-label;
                                        font-family: ThemePalette.font-sans;
                                        font-size: ThemePalette.fs-28;
                                        font-weight: 600;
                                        color: root.state-color;
                                    }
                                }
                            }
                            Rectangle { }
                            VerticalLayout {
                                spacing: 6px;
                                alignment: start;
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;
                                    Text {
                                        text: I18n.t(I18n.lang, "home.mode");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-10;
                                        color: ThemePalette.text-4;
                                        letter-spacing: 1px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: !root.running ? "—" : root.status.running_mode == "WindowsService" ? I18n.t(I18n.lang, "home.mode_service") : I18n.t(I18n.lang, "home.mode_user");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;
                                    Text {
                                        text: I18n.t(I18n.lang, "home.pid");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-10;
                                        color: ThemePalette.text-4;
                                        letter-spacing: 1px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.status.winws_pid > 0 ? "\{root.status.winws_pid}" : "—";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: end;
                                    Text {
                                        text: I18n.t(I18n.lang, "home.uptime");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-10;
                                        color: ThemePalette.text-4;
                                        letter-spacing: 1px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.running ? root.pad2(root.up-h) + ":" + root.pad2(root.up-m) + ":" + root.pad2(root.up-s) : "—";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                    }
                                }
                            }
                        }

                        // power-bar
                        Rectangle {
                            height: max(76px, pb.preferred-height);
                            border-radius: ThemePalette.r-12;
                            border-width: 1px;
                            border-color: ThemePalette.border-strong;
                            background: ThemePalette.bg-2;
                            clip: true;

                            pb := HorizontalLayout {
                                // info column
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    padding-top: 14px;
                                    padding-bottom: 14px;
                                    spacing: 6px;
                                    alignment: center;
                                    Text {
                                        text: root.running ? I18n.t(I18n.lang, "home.currently_running") : I18n.t(I18n.lang, "home.ready_to_engage");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-10;
                                        color: ThemePalette.text-3;
                                        letter-spacing: 1.4px;
                                    }
                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: start;
                                        Text {
                                            text: root.has_strategy ? root.chosen_item.pretty : I18n.t(I18n.lang, "home.no_strategy");
                                            font-family: ThemePalette.font-sans;
                                            font-size: ThemePalette.fs-16;
                                            font-weight: 600;
                                            color: root.has_strategy ? ThemePalette.text : ThemePalette.text-3;
                                            overflow: elide;
                                            vertical-alignment: center;
                                        }
                                        if root.has_strategy && root.chosen_item.alt != "" : Rectangle {
                                            horizontal-stretch: 0;
                                            width: alt-txt.preferred-width + 12px;
                                            height: 20px;
                                            border-radius: ThemePalette.r-4;
                                            background: ThemePalette.surface;
                                            border-width: 1px;
                                            border-color: ThemePalette.border;
                                            alt-txt := Text {
                                                text: root.chosen_item.alt;
                                                font-family: ThemePalette.font-mono;
                                                font-size: ThemePalette.fs-12;
                                                color: ThemePalette.text-2;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                    Text {
                                        text: !root.installed ? I18n.t(I18n.lang, "home.hint_install")
                                            : !root.has_strategy ? I18n.t(I18n.lang, "home.hint_pick")
                                            : root.running ? I18n.t(I18n.lang, "home.hint_stop")
                                            : I18n.t(I18n.lang, "home.hint_engage");
                                        font-family: ThemePalette.font-sans;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-3;
                                        wrap: word-wrap;
                                    }
                                }
                                // action button cell
                                pwr := Rectangle {
                                    horizontal-stretch: 0;
                                    width: 200px;
                                    // Foreground (icon + label) colour, shared by both.
                                    property <color> fg: root.transitioning ? (root.pending_op == "stop" ? #ffffff : ThemePalette.accent-ink)
                                        : !root.has_strategy ? ThemePalette.text
                                        : root.running ? #ffffff
                                        : (root.can-engage ? ThemePalette.accent-ink : ThemePalette.text-4);
                                    background: root.transitioning ? (root.pending_op == "stop" ? ThemePalette.danger : ThemePalette.accent)
                                        : !root.has_strategy ? ThemePalette.surface-2
                                        : root.running ? (pbta.has-hover ? ThemePalette.danger-hover : ThemePalette.danger)
                                        : !root.can-engage ? ThemePalette.surface-2
                                        : (pbta.has-hover ? ThemePalette.accent-hover : ThemePalette.accent);
                                    // Mid-transition the button mutes slightly so it reads as "working".
                                    opacity: root.transitioning ? 0.78 : 1.0;
                                    animate background, opacity { duration: 120ms; }
                                    Rectangle {
                                        x: 0; width: 1px;
                                        background: ThemePalette.border-strong;
                                    }
                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 12px;
                                        if root.transitioning : Spinner {
                                            size: 18px;
                                            tint: pwr.fg;
                                        }
                                        if !root.transitioning : Icon {
                                            source: !root.has_strategy ? @image-url("../../assets/icons/arrow-right.svg")
                                                : root.running ? @image-url("../../assets/icons/stop.svg")
                                                : @image-url("../../assets/icons/play.svg");
                                            size: 18px;
                                            tint: pwr.fg;
                                        }
                                        Text {
                                            text: root.transitioning ? (root.pending_op == "stop" ? I18n.t(I18n.lang, "home.btn_stopping") : I18n.t(I18n.lang, "home.btn_starting"))
                                                : !root.has_strategy ? I18n.t(I18n.lang, "home.btn_pick")
                                                : root.running ? I18n.t(I18n.lang, "home.btn_stop")
                                                : I18n.t(I18n.lang, "home.btn_engage");
                                            font-family: ThemePalette.font-sans;
                                            font-size: ThemePalette.fs-16;
                                            font-weight: 600;
                                            letter-spacing: 0.3px;
                                            color: pwr.fg;
                                            vertical-alignment: center;
                                        }
                                    }
                                    pbta := TouchArea {
                                        enabled: !root.transitioning && (!root.has_strategy || root.running || root.can-engage);
                                        mouse-cursor: self.enabled ? MouseCursor.pointer : MouseCursor.default;
                                        clicked => {
                                            if (!root.has_strategy) { root.pick_strategy_clicked(); }
                                            else if (root.running) { root.stop_clicked(); }
                                            else { root.start_clicked(); }
                                        }
                                    }
                                }
                            }
                        }

                        // stats-strip
                        Rectangle {
                            height: 64px;
                            border-radius: ThemePalette.r-12;
                            border-width: 1px;
                            border-color: ThemePalette.border;
                            background: ThemePalette.surface;
                            clip: true;
                            HorizontalLayout {
                                Stat { label: I18n.t(I18n.lang, "home.stat_app"); value: root.app_version; }
                                Stat {
                                    label: I18n.t(I18n.lang, "home.stat_core");
                                    value: root.installed ? root.status.installed_version : I18n.t(I18n.lang, "common.not_installed");
                                    value-color: root.installed ? ThemePalette.text : ThemePalette.text-3;
                                }
                                Stat {
                                    label: I18n.t(I18n.lang, "home.stat_latest");
                                    value: (root.status.latest_version != "" ? root.status.latest_version : "—") + (root.has-update ? " ↑" : "");
                                    value-color: root.has-update ? ThemePalette.accent : ThemePalette.text;
                                }
                                Stat { label: I18n.t(I18n.lang, "home.stat_strategies"); value: "\{root.strategy_count}"; last: true; }
                            }
                        }
                    }
                }

                Rectangle { height: 24px; }

                // ── SERVICE + STRATEGY ROW ──
                HorizontalLayout {
                    spacing: 12px;

                    ServiceCard {
                        horizontal-stretch: 14;
                        status: root.status;
                        is_busy: root.is_busy;
                        pending_op: root.pending_op;
                        has_strategy: root.has_strategy;
                        is_admin: root.is_admin;
                        chosen_item: root.chosen_item;
                        install_clicked => { root.service_install_clicked(); }
                        start_clicked => { root.service_start_clicked(); }
                        stop_clicked => { root.service_stop_clicked(); }
                        remove_clicked => { root.service_remove_clicked(); }
                    }

                    // strategy detail
                    Rectangle {
                        horizontal-stretch: 10;
                        background: ThemePalette.surface;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        border-radius: ThemePalette.r-12;
                        clip: true;
                        vertical-stretch: 0;
                        VerticalLayout {
                            alignment: start;
                            Rectangle {
                                height: 48px;
                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    Text {
                                        text: I18n.t(I18n.lang, "home.strategy_detail");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        font-weight: 600;
                                        color: ThemePalette.text-3;
                                        letter-spacing: 0.6px;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
                            }
                            VerticalLayout {
                                padding: 16px;
                                spacing: 0px;
                                DetailRow { key: I18n.t(I18n.lang, "home.detail_profile"); value: root.has_strategy ? root.chosen_item.pretty : "—"; }
                                DetailRow { key: I18n.t(I18n.lang, "home.detail_variant"); value: root.chosen_item.alt != "" ? root.chosen_item.alt : I18n.t(I18n.lang, "home.variant_default"); }
                                DetailRow { key: I18n.t(I18n.lang, "home.detail_core"); value: root.status.installed_version != "" ? root.status.installed_version : "—"; last: true; }
                                Rectangle { height: 12px; }
                                HorizontalLayout {
                                    alignment: start;
                                    AppButton {
                                        text: I18n.t(I18n.lang, "home.change_strategy");
                                        size: "sm";
                                        icon: @image-url("../../assets/icons/strategies.svg");
                                        clicked => { root.pick_strategy_clicked(); }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 16px; }

                // ── DPI FILTERS (game filter + ipset, side by side) ──
                HorizontalLayout {
                    spacing: 12px;

                    // game filter
                    FilterCard {
                        icon: @image-url("../../assets/icons/gamepad.svg");
                        title: I18n.t(I18n.lang, "common.game_filter");
                        hint: root.installed
                            ? I18n.t(I18n.lang, "home.game_filter_hint")
                            : I18n.t(I18n.lang, "common.game_filter_hint_install");
                        // A fixed-width Segmented placed directly in the card's
                        // VerticalLayout would cap the whole card's max-width to its
                        // own; wrapping it in a start-aligned row keeps it natural-
                        // width yet lets the card fill its half of the row.
                        HorizontalLayout {
                            alignment: start;
                            Segmented {
                                enabled: root.installed;
                                selected: root.game_filter;
                                options: [
                                    { value: "off", label: I18n.t(I18n.lang, "common.gf_off") },
                                    { value: "all", label: I18n.t(I18n.lang, "common.gf_all") },
                                    { value: "tcp", label: I18n.t(I18n.lang, "common.gf_tcp") },
                                    { value: "udp", label: I18n.t(I18n.lang, "common.gf_udp") },
                                ];
                                changed(v) => { root.game_filter = v; root.game_filter_changed(v); }
                            }
                        }
                    }

                    // ipset filter + update / staleness reminder
                    FilterCard {
                        icon: @image-url("../../assets/icons/shield.svg");
                        title: I18n.t(I18n.lang, "settings.ipset_label");
                        hint: root.installed
                            ? I18n.t(I18n.lang, "home.ipset_hint")
                            : I18n.t(I18n.lang, "common.game_filter_hint_install");
                        HorizontalLayout {
                            alignment: start;
                            Segmented {
                                enabled: root.installed && root.ipset_mode != "unknown";
                                selected: root.ipset_mode;
                                options: [
                                    { value: "loaded", label: I18n.t(I18n.lang, "settings.ipset_loaded") },
                                    { value: "none", label: I18n.t(I18n.lang, "settings.ipset_none") },
                                    { value: "any", label: I18n.t(I18n.lang, "settings.ipset_any") },
                                ];
                                changed(v) => { root.ipset_mode = v; root.ipset_mode_changed(v); }
                            }
                        }

                        // update strip — turns into a warning-tinted nudge when the
                        // loaded list is getting old.
                        Rectangle {
                            border-radius: ThemePalette.r-8;
                            border-width: 1px;
                            border-color: root.ipset-stale ? ThemePalette.warning : ThemePalette.border;
                            background: root.ipset-stale ? ThemePalette.warning-soft : ThemePalette.surface-2;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                padding-top: 10px;
                                padding-bottom: 10px;
                                spacing: 10px;
                                VerticalLayout {
                                    alignment: center;
                                    Icon {
                                        source: root.ipset-stale
                                            ? @image-url("../../assets/icons/warning.svg")
                                            : @image-url("../../assets/icons/download.svg");
                                        size: 14px;
                                        tint: root.ipset-stale ? ThemePalette.warning : ThemePalette.text-3;
                                    }
                                }
                                Text {
                                    horizontal-stretch: 1;
                                    text: root.ipset_msg != "" ? root.ipset_msg
                                        : root.ipset-stale ? I18n.t(I18n.lang, "home.ipset_stale_a") + root.ipset_age_days + I18n.t(I18n.lang, "home.ipset_stale_b")
                                        : root.ipset_mode == "loaded" ? I18n.t(I18n.lang, "home.ipset_loaded_a") + root.ipset_lines + I18n.t(I18n.lang, "home.ipset_loaded_b")
                                        : I18n.t(I18n.lang, "home.ipset_update_hint");
                                    font-family: ThemePalette.font-sans;
                                    font-size: ThemePalette.fs-12;
                                    color: root.ipset_msg != "" ? (root.ipset_ok ? ThemePalette.text-2 : ThemePalette.danger)
                                        : root.ipset-stale ? ThemePalette.warning
                                        : ThemePalette.text-3;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                }
                                VerticalLayout {
                                    alignment: center;
                                    AppButton {
                                        text: root.ipset_busy ? I18n.t(I18n.lang, "settings.updating") : I18n.t(I18n.lang, "common.update");
                                        size: "sm";
                                        variant: root.ipset-stale ? "primary" : "default";
                                        icon: @image-url("../../assets/icons/download.svg");
                                        enabled: root.installed && !root.ipset_busy;
                                        busy: root.ipset_busy;
                                        clicked => { root.update_ipset_clicked(); }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 16px; }

                // ── ACTION GRID ──
                HorizontalLayout {
                    spacing: 10px;
                    ActionTile {
                        icon: @image-url("../../assets/icons/download.svg");
                        title: root.installed ? I18n.t(I18n.lang, "home.reinstall") : I18n.t(I18n.lang, "home.install");
                        sub: root.installed ? I18n.t(I18n.lang, "home.redownload") : I18n.t(I18n.lang, "home.fetch_prefix") + (root.status.latest_version != "" ? root.status.latest_version : I18n.t(I18n.lang, "common.latest_word"));
                        highlight: !root.installed;
                        // Disabled while the bypass runs: replacing the install dir
                        // with winws.exe locked would fail / corrupt the install.
                        enabled: !root.is_busy && !root.running;
                        clicked => { root.install_clicked(); }
                    }
                    ActionTile {
                        icon: @image-url("../../assets/icons/refresh.svg");
                        title: root.has-update ? I18n.t(I18n.lang, "home.update_available") : I18n.t(I18n.lang, "home.check_updates");
                        sub: root.has-update ? root.status.installed_version + " → " + root.status.latest_version : "github.com / flowseal";
                        highlight: root.has-update;
                        enabled: !root.is_busy && !root.running;
                        clicked => { root.update_clicked(); }
                    }
                    ActionTile {
                        icon: @image-url("../../assets/icons/folder.svg");
                        title: I18n.t(I18n.lang, "home.open_folder");
                        sub: "…AppData\\Roaming\\zapret-ui";
                        enabled: root.installed;
                        clicked => { root.open_folder_clicked(); }
                    }
                }
            }
            Rectangle { } // right spacer keeps the column left-aligned
        }
    }
}
