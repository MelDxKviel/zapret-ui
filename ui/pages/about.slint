import { ThemePalette, AppStatus } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { BrandMark } from "../components/brand_mark.slint";
import { Icon } from "../components/icon.slint";
import { AppButton } from "../components/button.slint";
import { ScrollView } from "std-widgets.slint";

component AboutLink inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> url;
    callback clicked(string);
    height: 38px;
    border-radius: ThemePalette.r-8;
    background: ta.has-hover ? ThemePalette.surface-hover : transparent;
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;
        Icon {
            source: root.icon;
            size: 16px;
            tint: ThemePalette.text-3;
        }
        Text {
            text: root.label;
            font-family: ThemePalette.font-sans;
            font-size: ThemePalette.fs-13;
            color: ThemePalette.text;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Icon {
            source: @image-url("../../assets/icons/external.svg");
            size: 13px;
            tint: ThemePalette.text-4;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(root.url); }
    }
}

component VRow inherits Rectangle {
    in property <string> key;
    in property <bool> last: false;
    // min-height (not a fixed height) so a row whose value wraps onto several
    // lines (the app-version row when an update is available) can grow.
    min-height: 49px;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.key;
            font-family: ThemePalette.font-sans;
            font-size: ThemePalette.fs-13;
            color: ThemePalette.text-2;
            vertical-alignment: center;
        }
        Rectangle { }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            @children
        }
    }
    if !root.last : Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
}

component AccentPill inherits Rectangle {
    in property <string> text;
    horizontal-stretch: 0;
    height: 22px;
    border-radius: ThemePalette.r-full;
    background: ThemePalette.accent-soft;
    border-width: 1px;
    border-color: ThemePalette.accent-line;
    clip: true;
    // A layout-wrapped (not free-floating) Text so the pill reports a real
    // preferred width AND a shrinkable min-width: when the version string is long
    // (e.g. a git-describe build like v0.1.0-5-gabc-dirty) the text elides here
    // instead of forcing the parent card past the window edge.
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.text;
            font-family: ThemePalette.font-mono;
            font-size: ThemePalette.fs-11;
            color: ThemePalette.accent;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component AboutPage inherits Rectangle {
    in property <AppStatus> status;
    in property <string> app_version;
    in property <string> repo_url;
    // App self-update (zapret-ui itself).
    in property <bool> app_has_update;
    in property <string> app_latest_version;
    in property <bool> app_update_downloading;
    callback open_url(string);
    callback app_update_clicked();

    background: transparent;

    sv := ScrollView {
        viewport-width: sv.visible-width;
        HorizontalLayout {
            VerticalLayout {
                horizontal-stretch: 0;
                width: min(sv.visible-width - 64px, 980px);
                padding-left: 32px;
                padding-top: 28px;
                padding-right: 32px;
                padding-bottom: 60px;
                spacing: 0px;
                alignment: start;

                // page-head
                VerticalLayout {
                    spacing: 2px;
                    padding-bottom: 20px;
                    Text {
                        text: I18n.t(I18n.lang, "about.title");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-22;
                        font-weight: 600;
                        color: ThemePalette.text;
                    }
                    Text {
                        text: I18n.t(I18n.lang, "about.subtitle");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-13;
                        color: ThemePalette.text-3;
                    }
                }
                Rectangle { height: 1px; background: ThemePalette.divider; }
                Rectangle { height: 20px; }

                // about-grid — stretch (no `alignment: start`) so the two columns
                // share the capped container width instead of growing to their
                // content's preferred width (a long version string used to push
                // the system card off the right edge).
                HorizontalLayout {
                    spacing: 20px;

                    // LEFT — hero
                    Rectangle {
                        horizontal-stretch: 11;
                        vertical-stretch: 0;
                        background: ThemePalette.surface;
                        border-width: 1px;
                        border-color: ThemePalette.border;
                        border-radius: ThemePalette.r-12;
                        VerticalLayout {
                            padding: 24px;
                            spacing: 0px;
                            alignment: start;

                            // mark
                            HorizontalLayout {
                                spacing: 14px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    BrandMark { size: 44px; }
                                }
                                VerticalLayout {
                                    spacing: 2px;
                                    alignment: center;
                                    Text {
                                        text: "zapret-ui";
                                        font-family: ThemePalette.font-sans;
                                        font-size: ThemePalette.fs-22;
                                        font-weight: 600;
                                        color: ThemePalette.text;
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Rectangle {
                                            horizontal-stretch: 0;
                                            height: 20px;
                                            border-radius: ThemePalette.r-4;
                                            background: ThemePalette.surface-2;
                                            border-width: 1px;
                                            border-color: ThemePalette.border;
                                            clip: true;
                                            // Layout-wrapped + eliding so a long
                                            // git-describe version shrinks here instead
                                            // of overrunning the hero card / window.
                                            HorizontalLayout {
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                Text {
                                                    text: root.app_version;
                                                    font-family: ThemePalette.font-mono;
                                                    font-size: ThemePalette.fs-12;
                                                    color: ThemePalette.text-3;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }
                                            }
                                        }
                                        Text {
                                            text: "·";
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-12;
                                            color: ThemePalette.text-4;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Rust + Slint";
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-12;
                                            color: ThemePalette.text-3;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            Rectangle { height: 16px; }
                            Text {
                                text: I18n.t(I18n.lang, "about.description");
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-13;
                                color: ThemePalette.text-2;
                                wrap: word-wrap;
                            }
                            Rectangle { height: 18px; }
                            Rectangle { height: 1px; background: ThemePalette.divider; }
                            Rectangle { height: 18px; }
                            AboutLink {
                                icon: @image-url("../../assets/icons/github.svg");
                                label: I18n.t(I18n.lang, "about.project_repo");
                                url: root.repo_url;
                                clicked(u) => { root.open_url(u); }
                            }
                            AboutLink {
                                icon: @image-url("../../assets/icons/rocket.svg");
                                label: I18n.t(I18n.lang, "about.release_notes");
                                url: root.repo_url + "/releases";
                                clicked(u) => { root.open_url(u); }
                            }
                            AboutLink {
                                icon: @image-url("../../assets/icons/shield.svg");
                                label: I18n.t(I18n.lang, "about.upstream");
                                url: "https://github.com/Flowseal/zapret-discord-youtube";
                                clicked(u) => { root.open_url(u); }
                            }
                            AboutLink {
                                icon: @image-url("../../assets/icons/shield.svg");
                                label: I18n.t(I18n.lang, "about.how_it_works");
                                url: "https://github.com/Flowseal/zapret-discord-youtube#readme";
                                clicked(u) => { root.open_url(u); }
                            }
                        }
                    }

                    // RIGHT — system card + callout
                    VerticalLayout {
                        horizontal-stretch: 10;
                        spacing: 18px;
                        alignment: start;

                        Rectangle {
                            vertical-stretch: 0;
                            background: ThemePalette.surface;
                            border-width: 1px;
                            border-color: ThemePalette.border;
                            border-radius: ThemePalette.r-12;
                            clip: true;
                            VerticalLayout {
                                alignment: start;
                                Rectangle {
                                    height: 44px;
                                    background: ThemePalette.bg-2;
                                    HorizontalLayout {
                                        padding-left: 16px;
                                        padding-right: 16px;
                                        Text {
                                            text: I18n.t(I18n.lang, "about.system");
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-11;
                                            font-weight: 600;
                                            color: ThemePalette.text-3;
                                            letter-spacing: 1px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
                                }
                                VRow {
                                    key: I18n.t(I18n.lang, "about.app_version");
                                    // Stack the version pill, the "↑ latest" pill and the
                                    // update button vertically (right-aligned) so a long
                                    // version + update affordance can't overrun the card.
                                    VerticalLayout {
                                        spacing: 6px;
                                        alignment: center;
                                        padding-top: 12px;
                                        padding-bottom: 12px;
                                        HorizontalLayout {
                                            alignment: end;
                                            AccentPill { text: root.app_version; }
                                        }
                                        if root.app_has_update : HorizontalLayout {
                                            alignment: end;
                                            AccentPill { text: "↑ " + root.app_latest_version; }
                                        }
                                        if root.app_has_update : HorizontalLayout {
                                            alignment: end;
                                            AppButton {
                                                text: root.app_update_downloading
                                                    ? I18n.t(I18n.lang, "update.downloading")
                                                    : I18n.t(I18n.lang, "common.update");
                                                variant: "primary";
                                                size: "sm";
                                                busy: root.app_update_downloading;
                                                icon: @image-url("../../assets/icons/download.svg");
                                                clicked => { root.app_update_clicked(); }
                                            }
                                        }
                                    }
                                }
                                VRow {
                                    key: I18n.t(I18n.lang, "about.zapret_core");
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: end;
                                        if root.status.installed : Text {
                                            text: root.status.installed_version;
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-12;
                                            color: ThemePalette.text;
                                            vertical-alignment: center;
                                        }
                                        if root.status.installed && root.status.update_available : AccentPill {
                                            text: "↑ " + root.status.latest_version;
                                        }
                                        if !root.status.installed : Text {
                                            text: I18n.t(I18n.lang, "common.not_installed");
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-12;
                                            color: ThemePalette.danger;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                VRow {
                                    key: I18n.t(I18n.lang, "about.platform");
                                    Text {
                                        text: "Windows 10 / 11";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                        vertical-alignment: center;
                                    }
                                }
                                VRow {
                                    key: I18n.t(I18n.lang, "about.architecture");
                                    Text {
                                        text: "x86_64";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                        vertical-alignment: center;
                                    }
                                }
                                VRow {
                                    key: I18n.t(I18n.lang, "about.build_channel");
                                    last: true;
                                    Text {
                                        text: I18n.t(I18n.lang, "about.stable");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        // amber callout
                        Rectangle {
                            vertical-stretch: 0;
                            border-radius: ThemePalette.r-12;
                            border-width: 1px;
                            border-color: ThemePalette.warning;
                            background: ThemePalette.warning-soft;
                            HorizontalLayout {
                                padding: 14px;
                                spacing: 12px;
                                alignment: start;
                                Image {
                                    source: @image-url("../../assets/icons/warning.svg");
                                    width: 18px; height: 18px;
                                    colorize: ThemePalette.warning;
                                }
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;
                                    Text {
                                        text: I18n.t(I18n.lang, "about.av_title");
                                        font-family: ThemePalette.font-sans;
                                        font-size: ThemePalette.fs-13;
                                        font-weight: 600;
                                        color: ThemePalette.text;
                                    }
                                    Text {
                                        text: I18n.t(I18n.lang, "about.av_desc");
                                        font-family: ThemePalette.font-sans;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-2;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            Rectangle { }
        }
    }
}
