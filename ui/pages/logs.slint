import { ThemePalette, LogLineItem } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { AppButton } from "../components/button.slint";
import { AppInput } from "../components/input.slint";
import { Segmented } from "../components/segmented.slint";
import { TextEdit } from "std-widgets.slint";

export component LogsPage inherits Rectangle {
    in property <[LogLineItem]> log_lines;
    // Plain-text mirror of the (filtered) log buffer for select & copy.
    in property <string> log_text;
    in-out property <string> query;
    in-out property <string> level: "ALL";
    in-out property <bool> autoscroll: true;

    callback open_file_clicked();
    callback clear_clicked();
    callback query_changed(string, string); // grep, level

    background: transparent;

    property <int> count: root.log_lines.length;
    changed count => {
        if (root.autoscroll) {
            term.viewport-y = -(term.viewport-height - term.visible-height);
        }
    }

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 0;
            width: min(parent.width - 64px, 980px);
            padding-left: 32px;
            padding-top: 28px;
            padding-right: 32px;
            padding-bottom: 28px;
            spacing: 0px;

            // page-head
            HorizontalLayout {
                padding-bottom: 20px;
                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text {
                        text: I18n.t(I18n.lang, "logs.title");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-22;
                        font-weight: 600;
                        color: ThemePalette.text;
                    }
                    Text {
                        text: I18n.t(I18n.lang, "logs.subtitle");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-13;
                        color: ThemePalette.text-3;
                    }
                }
                Rectangle { }
                VerticalLayout {
                    alignment: end;
                    HorizontalLayout {
                        spacing: 8px;
                        AppButton {
                            text: I18n.t(I18n.lang, "logs.open_file");
                            icon: @image-url("../../assets/icons/external.svg");
                            clicked => { root.open_file_clicked(); }
                        }
                        AppButton {
                            text: I18n.t(I18n.lang, "common.clear");
                            variant: "danger";
                            icon: @image-url("../../assets/icons/trash.svg");
                            clicked => { root.clear_clicked(); }
                        }
                    }
                }
            }
            Rectangle { height: 1px; background: ThemePalette.divider; }
            Rectangle { height: 16px; }

            // logs shell
            Rectangle {
                vertical-stretch: 1;
                border-width: 1px;
                border-color: ThemePalette.border;
                border-radius: ThemePalette.r-12;
                background: ThemePalette.surface;
                clip: true;

                VerticalLayout {
                    // toolbar
                    Rectangle {
                        height: 48px;
                        background: ThemePalette.bg-2;
                        VerticalLayout {
                          height: 100%;
                          alignment: center;
                          HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;

                            // streaming stat
                            HorizontalLayout {
                                horizontal-stretch: 0;
                                spacing: 6px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 6px; height: 6px; border-radius: 3px;
                                        background: ThemePalette.accent;
                                    }
                                }
                                Text {
                                    text: I18n.t(I18n.lang, "logs.streaming_a") + root.count + I18n.t(I18n.lang, "logs.streaming_b");
                                    font-family: ThemePalette.font-mono;
                                    font-size: ThemePalette.fs-11;
                                    color: ThemePalette.text-3;
                                    vertical-alignment: center;
                                }
                            }

                            // grep — fills the middle of the toolbar and grows
                            // with the window instead of a fixed pinned-right box.
                            AppInput {
                                horizontal-stretch: 1;
                                min-width: 160px;
                                field-height: 28px;
                                font-size: ThemePalette.fs-12;
                                icon: @image-url("../../assets/icons/search.svg");
                                placeholder: I18n.t(I18n.lang, "logs.grep_placeholder");
                                text <=> root.query;
                                edited(t) => { root.query_changed(t, root.level); }
                            }

                            // level filter
                            Segmented {
                                seg-height: 22px;
                                seg-pad: 8px;
                                seg-fs: ThemePalette.fs-11;
                                selected: root.level;
                                options: [
                                    { value: "ALL",   label: "ALL" },
                                    { value: "INFO",  label: "INFO" },
                                    { value: "WARN",  label: "WARN" },
                                    { value: "ERROR", label: "ERROR" },
                                ];
                                changed(v) => { root.level = v; root.query_changed(root.query, v); }
                            }

                            // autoscroll
                            AppButton {
                                text: I18n.t(I18n.lang, "logs.auto");
                                size: "sm";
                                variant: root.autoscroll ? "primary" : "default";
                                icon: @image-url("../../assets/icons/pin.svg");
                                clicked => {
                                    root.autoscroll = !root.autoscroll;
                                    if (root.autoscroll) {
                                        term.viewport-y = -(term.viewport-height - term.visible-height);
                                    }
                                }
                            }
                          }
                        }
                        Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.border; }
                    }

                    // terminal body — a real TextEdit so the log can be
                    // drag-selected and copied (Ctrl+C) directly in the block, with
                    // its own scrollbar. (A TextInput inside a ScrollView made
                    // drag-to-select unreliable, which is why a Copy button used to
                    // be needed.) It exposes viewport-y, so autoscroll still works.
                    // The TextEdit is wrapped in a FocusScope so Ctrl+C works on
                    // non-Latin keyboard layouts too. Slint's built-in TextInput
                    // matches the copy shortcut against the *produced character*
                    // ("c"); on a Russian layout Ctrl+C yields "с" (Cyrillic) and
                    // the built-in copy never fires. When the shortcut doesn't match,
                    // the (Ctrl-held) TextInput reports the event as ignored, so it
                    // bubbles up here and we invoke TextEdit::copy() ourselves —
                    // which copies the current *selection* via Slint's clipboard,
                    // exactly like the native shortcut. On a Latin layout the
                    // TextInput consumes Ctrl+C itself and this handler isn't reached.
                    FocusScope {
                        vertical-stretch: 1;
                        key-pressed(event) => {
                            if (event.modifiers.control
                                && (event.text == "c" || event.text == "с" || event.text == "С")) {
                                term.copy();
                                return accept;
                            }
                            return reject;
                        }
                        term := TextEdit {
                            width: 100%;
                            height: 100%;
                            read-only: true;
                            text: root.log_text;
                            font-family: ThemePalette.font-mono;
                            font-size: ThemePalette.fs-12;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
        Rectangle { }
    }
}
