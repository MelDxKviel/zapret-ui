import { ThemePalette } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { AppSwitch } from "../components/switch.slint";
import { AppButton } from "../components/button.slint";
import { Segmented, SegmentOption } from "../components/segmented.slint";
import { Icon } from "../components/icon.slint";
import { ScrollView } from "std-widgets.slint";

component SettingsGroup inherits Rectangle {
    in property <string> title;
    background: ThemePalette.surface;
    border-width: 1px;
    border-color: ThemePalette.border;
    border-radius: ThemePalette.r-12;
    clip: true;
    vertical-stretch: 0;
    VerticalLayout {
        alignment: start;
        Rectangle {
            height: 44px;
            background: ThemePalette.bg-2;
            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                Text {
                    text: root.title;
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-11;
                    font-weight: 600;
                    color: ThemePalette.text-3;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
        }
        @children
    }
}

component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <bool> last: false;
    vertical-stretch: 0;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 16px;
        padding-bottom: 16px;
        spacing: 24px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: root.label;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-13;
                font-weight: 500;
                color: ThemePalette.text;
            }
            Text {
                text: root.hint;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-12;
                color: ThemePalette.text-3;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            @children
        }
    }
    if !root.last : Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
}

export component SettingsPage inherits Rectangle {
    in-out property <bool> autostart;
    in-out property <bool> autoupdate_check;
    in-out property <bool> minimize_to_tray;
    in-out property <bool> autoengage;
    in-out property <bool> compact;
    in-out property <string> install_dir;
    in-out property <string> theme; // "dark" | "light" | "system"

    // ── DPI bypass tuning (zapret service.bat filters) ──
    in property <bool> installed;
    in-out property <string> game_filter; // off | all | tcp | udp
    in-out property <string> ipset_mode;  // any | none | loaded | unknown
    in property <int> ipset_lines;
    in property <bool> ipset_busy;
    in property <string> ipset_msg;
    in property <bool> ipset_ok;
    in property <bool> hosts_busy;
    in property <string> hosts_msg;
    in property <bool> hosts_ok;

    callback open_folder_clicked();
    callback theme_changed(string);
    callback language_changed(string);
    callback game_filter_changed(string);
    callback ipset_mode_changed(string);
    callback update_ipset_clicked();
    callback update_hosts_clicked();

    background: transparent;

    sv := ScrollView {
        viewport-width: sv.visible-width;
        HorizontalLayout {
            VerticalLayout {
                horizontal-stretch: 0;
                width: min(sv.visible-width - 64px, 980px);
                padding-left: 32px;
                padding-top: 28px;
                padding-right: 32px;
                padding-bottom: 60px;
                spacing: 0px;
                alignment: start;

                // page-head
                VerticalLayout {
                    spacing: 2px;
                    padding-bottom: 20px;
                    Text {
                        text: I18n.t(I18n.lang, "settings.title");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-22;
                        font-weight: 600;
                        color: ThemePalette.text;
                    }
                    Text {
                        text: I18n.t(I18n.lang, "settings.subtitle");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-13;
                        color: ThemePalette.text-3;
                    }
                }
                Rectangle { height: 1px; background: ThemePalette.divider; }
                Rectangle { height: 16px; }

                // Application
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_application");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.autostart_label");
                        hint: I18n.t(I18n.lang, "settings.autostart_hint");
                        AppSwitch { checked <=> root.autostart; }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.tray_label");
                        hint: I18n.t(I18n.lang, "settings.tray_hint");
                        AppSwitch { checked <=> root.minimize_to_tray; }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.autoengage_label");
                        hint: I18n.t(I18n.lang, "settings.autoengage_hint");
                        last: true;
                        AppSwitch { checked <=> root.autoengage; }
                    }
                }
                Rectangle { height: 16px; }

                // Updates & paths
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_updates");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.autoupdate_label");
                        hint: I18n.t(I18n.lang, "settings.autoupdate_hint");
                        AppSwitch { checked <=> root.autoupdate_check; }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.installdir_label");
                        hint: I18n.t(I18n.lang, "settings.installdir_hint");
                        last: true;
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                horizontal-stretch: 0;
                                width: 240px;
                                height: 32px;
                                border-radius: ThemePalette.r-8;
                                border-width: 1px;
                                border-color: ThemePalette.border;
                                background: ThemePalette.bg-2;
                                clip: true;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    Icon {
                                        source: @image-url("../../assets/icons/folder.svg");
                                        size: 13px;
                                        tint: ThemePalette.text-3;
                                    }
                                    Text {
                                        text: root.install_dir != "" ? root.install_dir : "%APPDATA%\\zapret-ui\\zapret";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                            AppButton {
                                text: I18n.t(I18n.lang, "common.open");
                                icon: @image-url("../../assets/icons/external.svg");
                                clicked => { root.open_folder_clicked(); }
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // DPI bypass tuning — the zapret service.bat filters & updaters.
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_dpi");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "common.game_filter");
                        hint: root.installed
                            ? I18n.t(I18n.lang, "settings.gf_hint")
                            : I18n.t(I18n.lang, "common.game_filter_hint_install");
                        Segmented {
                            enabled: root.installed;
                            selected: root.game_filter;
                            options: [
                                { value: "off", label: I18n.t(I18n.lang, "common.gf_off") },
                                { value: "all", label: I18n.t(I18n.lang, "common.gf_all") },
                                { value: "tcp", label: I18n.t(I18n.lang, "common.gf_tcp") },
                                { value: "udp", label: I18n.t(I18n.lang, "common.gf_udp") },
                            ];
                            changed(v) => { root.game_filter = v; root.game_filter_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.ipset_label");
                        hint: root.ipset_mode == "loaded"
                            ? I18n.t(I18n.lang, "settings.ipset_hint_loaded_a") + root.ipset_lines + I18n.t(I18n.lang, "settings.ipset_hint_loaded_b")
                            : (root.ipset_mode == "none"
                                ? I18n.t(I18n.lang, "settings.ipset_hint_none")
                                : (root.ipset_mode == "any"
                                    ? I18n.t(I18n.lang, "settings.ipset_hint_any")
                                    : I18n.t(I18n.lang, "settings.ipset_hint_default")));
                        Segmented {
                            enabled: root.installed && root.ipset_mode != "unknown";
                            selected: root.ipset_mode;
                            options: [
                                { value: "loaded", label: I18n.t(I18n.lang, "settings.ipset_loaded") },
                                { value: "none", label: I18n.t(I18n.lang, "settings.ipset_none") },
                                { value: "any", label: I18n.t(I18n.lang, "settings.ipset_any") },
                            ];
                            changed(v) => { root.ipset_mode = v; root.ipset_mode_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.update_ipset_label");
                        hint: I18n.t(I18n.lang, "settings.update_ipset_hint");
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.ipset_busy ? I18n.t(I18n.lang, "settings.updating") : I18n.t(I18n.lang, "common.update");
                                    icon: @image-url("../../assets/icons/download.svg");
                                    enabled: root.installed && !root.ipset_busy;
                                    clicked => { root.update_ipset_clicked(); }
                                }
                            }
                            if root.ipset_msg != "" : Text {
                                text: root.ipset_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.ipset_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.update_hosts_label");
                        hint: I18n.t(I18n.lang, "settings.update_hosts_hint");
                        last: true;
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.hosts_busy ? I18n.t(I18n.lang, "settings.checking") : I18n.t(I18n.lang, "settings.check_update");
                                    icon: @image-url("../../assets/icons/refresh.svg");
                                    enabled: !root.hosts_busy;
                                    clicked => { root.update_hosts_clicked(); }
                                }
                            }
                            if root.hosts_msg != "" : Text {
                                text: root.hosts_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.hosts_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // Appearance
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_appearance");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.language_label");
                        hint: I18n.t(I18n.lang, "settings.language_hint");
                        Segmented {
                            selected: I18n.lang;
                            options: [
                                { value: "ru", label: "Русский" },
                                { value: "en", label: "English" },
                            ];
                            changed(v) => { I18n.lang = v; root.language_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.theme_label");
                        hint: I18n.t(I18n.lang, "settings.theme_hint");
                        Segmented {
                            selected: root.theme;
                            options: [
                                { value: "dark",   label: I18n.t(I18n.lang, "settings.theme_dark"),   icon: @image-url("../../assets/icons/moon.svg") },
                                { value: "light",  label: I18n.t(I18n.lang, "settings.theme_light"),  icon: @image-url("../../assets/icons/sun.svg") },
                                { value: "system", label: I18n.t(I18n.lang, "settings.theme_system"), icon: @image-url("../../assets/icons/system.svg") },
                            ];
                            changed(v) => { root.theme = v; root.theme_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.compact_label");
                        hint: I18n.t(I18n.lang, "settings.compact_hint");
                        last: true;
                        AppSwitch { checked <=> root.compact; }
                    }
                }
            }
            Rectangle { }
        }
    }
}
