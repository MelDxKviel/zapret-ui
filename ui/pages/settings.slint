import { ThemePalette, HostlistInfoItem } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { AppSwitch } from "../components/switch.slint";
import { AppButton } from "../components/button.slint";
import { Segmented, SegmentOption } from "../components/segmented.slint";
import { Icon } from "../components/icon.slint";
import { ScrollView } from "std-widgets.slint";

component SettingsGroup inherits Rectangle {
    in property <string> title;
    background: ThemePalette.surface;
    border-width: 1px;
    border-color: ThemePalette.border;
    border-radius: ThemePalette.r-12;
    clip: true;
    vertical-stretch: 0;
    VerticalLayout {
        alignment: start;
        Rectangle {
            height: 44px;
            background: ThemePalette.bg-2;
            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                Text {
                    text: root.title;
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-11;
                    font-weight: 600;
                    color: ThemePalette.text-3;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
        }
        @children
    }
}

component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <bool> last: false;
    vertical-stretch: 0;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 16px;
        padding-bottom: 16px;
        spacing: 24px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: root.label;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-13;
                font-weight: 500;
                color: ThemePalette.text;
            }
            Text {
                text: root.hint;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-12;
                color: ThemePalette.text-3;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            @children
        }
    }
    if !root.last : Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
}

export component SettingsPage inherits Rectangle {
    in-out property <bool> autostart;
    in-out property <bool> minimize_to_tray;
    in-out property <bool> notifications;
    in-out property <bool> autoengage;
    in-out property <bool> compact;
    in-out property <string> install_dir;
    in-out property <string> theme; // "dark" | "light" | "system"

    // ── App self-update (zapret-ui itself) ──
    in property <string> app_version;
    in property <bool> app_has_update;
    in property <string> app_latest_version;
    in property <bool> app_update_checking;
    in property <bool> app_update_downloading;
    in property <float> app_update_progress;
    in property <bool> app_update_checked;
    in property <bool> app_update_ok;
    in property <string> app_update_msg;

    // ── DPI tuning (zapret2 hostlists; the Flowseal-port "game filter" /
    //    "ipset mode" / "hosts file" knobs go away — winws2 doesn't expose
    //    any of them on Windows). ──
    in property <bool> installed;
    in-out property <[HostlistInfoItem]> hostlists;
    in property <bool> hostlists_busy;
    in property <string> hostlists_msg;
    in property <bool> hostlists_ok;
    in property <bool> discord_busy;
    in property <string> discord_msg;
    in property <bool> discord_ok;

    callback open_folder_clicked();
    callback app_check_update_clicked();
    callback app_update_clicked();
    callback theme_changed(string);
    callback language_changed(string);
    callback notifications_changed(bool);
    callback autostart_changed(bool);
    callback tray_changed(bool);
    callback autoengage_changed(bool);
    callback update_hostlists_clicked();
    callback clear_discord_cache_clicked();

    background: transparent;

    sv := ScrollView {
        viewport-width: sv.visible-width;
        HorizontalLayout {
            VerticalLayout {
                horizontal-stretch: 0;
                width: min(sv.visible-width - 64px, 980px);
                padding-left: 32px;
                padding-top: 28px;
                padding-right: 32px;
                padding-bottom: 60px;
                spacing: 0px;
                alignment: start;

                // page-head
                VerticalLayout {
                    spacing: 2px;
                    padding-bottom: 20px;
                    Text {
                        text: I18n.t(I18n.lang, "settings.title");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-22;
                        font-weight: 600;
                        color: ThemePalette.text;
                    }
                    Text {
                        text: I18n.t(I18n.lang, "settings.subtitle");
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-13;
                        color: ThemePalette.text-3;
                    }
                }
                Rectangle { height: 1px; background: ThemePalette.divider; }
                Rectangle { height: 16px; }

                // Application
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_application");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.autostart_label");
                        hint: I18n.t(I18n.lang, "settings.autostart_hint");
                        AppSwitch {
                            checked <=> root.autostart;
                            toggled(v) => { root.autostart_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.tray_label");
                        hint: I18n.t(I18n.lang, "settings.tray_hint");
                        AppSwitch {
                            checked <=> root.minimize_to_tray;
                            toggled(v) => { root.tray_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.notifications_label");
                        hint: I18n.t(I18n.lang, "settings.notifications_hint");
                        AppSwitch {
                            checked <=> root.notifications;
                            toggled(v) => { root.notifications_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.autoengage_label");
                        hint: I18n.t(I18n.lang, "settings.autoengage_hint");
                        last: true;
                        AppSwitch {
                            checked <=> root.autoengage;
                            toggled(v) => { root.autoengage_changed(v); }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // Updates & paths
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_updates");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "update.settings_label");
                        hint: I18n.t(I18n.lang, "update.settings_hint");
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: end;
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: root.app_version;
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-3;
                                        vertical-alignment: center;
                                    }
                                }
                                AppButton {
                                    text: root.app_has_update
                                        ? (root.app_update_downloading
                                            ? I18n.t(I18n.lang, "update.downloading")
                                            : I18n.t(I18n.lang, "common.update"))
                                        : (root.app_update_checking
                                            ? I18n.t(I18n.lang, "settings.checking")
                                            : I18n.t(I18n.lang, "update.check_btn"));
                                    variant: root.app_has_update ? "primary" : "default";
                                    icon: root.app_has_update
                                        ? @image-url("../../assets/icons/download.svg")
                                        : @image-url("../../assets/icons/refresh.svg");
                                    busy: root.app_update_checking || root.app_update_downloading;
                                    enabled: !root.app_update_checking && !root.app_update_downloading;
                                    clicked => {
                                        if (root.app_has_update) {
                                            root.app_update_clicked();
                                        } else {
                                            root.app_check_update_clicked();
                                        }
                                    }
                                }
                            }
                            if (!root.app_update_ok && root.app_update_msg != "") || root.app_has_update || root.app_update_checked : Text {
                                text: (!root.app_update_ok && root.app_update_msg != "")
                                    ? root.app_update_msg
                                    : (root.app_has_update
                                        ? I18n.t(I18n.lang, "update.available_prefix") + root.app_latest_version
                                        : I18n.t(I18n.lang, "update.up_to_date"));
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: (!root.app_update_ok && root.app_update_msg != "")
                                    ? ThemePalette.danger
                                    : ThemePalette.text-3;
                            }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.installdir_label");
                        hint: I18n.t(I18n.lang, "settings.installdir_hint");
                        last: true;
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                horizontal-stretch: 0;
                                width: 240px;
                                height: 32px;
                                border-radius: ThemePalette.r-8;
                                border-width: 1px;
                                border-color: ThemePalette.border;
                                background: ThemePalette.bg-2;
                                clip: true;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    Icon {
                                        source: @image-url("../../assets/icons/folder.svg");
                                        size: 13px;
                                        tint: ThemePalette.text-3;
                                    }
                                    Text {
                                        text: root.install_dir != "" ? root.install_dir : "%APPDATA%\\zapret-ui\\zapret";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                            AppButton {
                                text: I18n.t(I18n.lang, "common.open");
                                icon: @image-url("../../assets/icons/external.svg");
                                clicked => { root.open_folder_clicked(); }
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // DPI tuning — zapret2 hostlists + Discord cache housekeeping.
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_dpi");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.hostlists_label");
                        hint: I18n.t(I18n.lang, "settings.hostlists_hint");
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.hostlists_busy ? I18n.t(I18n.lang, "settings.updating") : I18n.t(I18n.lang, "common.update");
                                    icon: @image-url("../../assets/icons/download.svg");
                                    enabled: root.installed && !root.hostlists_busy;
                                    busy: root.hostlists_busy;
                                    clicked => { root.update_hostlists_clicked(); }
                                }
                            }
                            // Per-list status line (only when at least one row is present).
                            for h[i] in root.hostlists : Text {
                                text: h.name + " · " + (h.age_days < 0 ? I18n.t(I18n.lang, "settings.hostlists_missing")
                                    : (h.age_days == 0 ? I18n.t(I18n.lang, "settings.hostlists_today")
                                                       : "\{h.age_days}" + I18n.t(I18n.lang, "settings.hostlists_days_ago")))
                                    + " · " + "\{h.line_count}" + I18n.t(I18n.lang, "settings.hostlists_entries_suffix");
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-mono;
                                font-size: ThemePalette.fs-11;
                                color: h.age_days < 0 ? ThemePalette.danger
                                    : (h.age_days >= 30 ? ThemePalette.warning : ThemePalette.text-3);
                            }
                            if root.hostlists_msg != "" : Text {
                                text: root.hostlists_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.hostlists_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.discord_cache_label");
                        hint: I18n.t(I18n.lang, "settings.discord_cache_hint");
                        last: true;
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.discord_busy ? I18n.t(I18n.lang, "settings.clearing") : I18n.t(I18n.lang, "common.clear");
                                    icon: @image-url("../../assets/icons/trash.svg");
                                    enabled: !root.discord_busy;
                                    clicked => { root.clear_discord_cache_clicked(); }
                                }
                            }
                            if root.discord_msg != "" : Text {
                                text: root.discord_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.discord_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // Appearance
                SettingsGroup {
                    title: I18n.t(I18n.lang, "settings.group_appearance");
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.language_label");
                        hint: I18n.t(I18n.lang, "settings.language_hint");
                        Segmented {
                            selected: I18n.lang;
                            options: [
                                { value: "ru", label: "Русский" },
                                { value: "en", label: "English" },
                            ];
                            changed(v) => { I18n.lang = v; root.language_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: I18n.t(I18n.lang, "settings.theme_label");
                        hint: I18n.t(I18n.lang, "settings.theme_hint");
                        last: true;
                        Segmented {
                            selected: root.theme;
                            options: [
                                { value: "dark",   label: I18n.t(I18n.lang, "settings.theme_dark"),   icon: @image-url("../../assets/icons/moon.svg") },
                                { value: "light",  label: I18n.t(I18n.lang, "settings.theme_light"),  icon: @image-url("../../assets/icons/sun.svg") },
                                { value: "system", label: I18n.t(I18n.lang, "settings.theme_system"), icon: @image-url("../../assets/icons/system.svg") },
                            ];
                            changed(v) => { root.theme = v; root.theme_changed(v); }
                        }
                    }
                }
            }
            Rectangle { }
        }
    }
}
