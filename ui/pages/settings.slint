import { ThemePalette } from "../tokens.slint";
import { AppSwitch } from "../components/switch.slint";
import { AppButton } from "../components/button.slint";
import { Segmented, SegmentOption } from "../components/segmented.slint";
import { Icon } from "../components/icon.slint";
import { ScrollView } from "std-widgets.slint";

component SettingsGroup inherits Rectangle {
    in property <string> title;
    background: ThemePalette.surface;
    border-width: 1px;
    border-color: ThemePalette.border;
    border-radius: ThemePalette.r-12;
    clip: true;
    vertical-stretch: 0;
    VerticalLayout {
        alignment: start;
        Rectangle {
            height: 44px;
            background: ThemePalette.bg-2;
            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                Text {
                    text: root.title;
                    font-family: ThemePalette.font-mono;
                    font-size: ThemePalette.fs-11;
                    font-weight: 600;
                    color: ThemePalette.text-3;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
        }
        @children
    }
}

component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <bool> last: false;
    vertical-stretch: 0;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 16px;
        padding-bottom: 16px;
        spacing: 24px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: root.label;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-13;
                font-weight: 500;
                color: ThemePalette.text;
            }
            Text {
                text: root.hint;
                font-family: ThemePalette.font-sans;
                font-size: ThemePalette.fs-12;
                color: ThemePalette.text-3;
                wrap: word-wrap;
            }
        }
        VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            @children
        }
    }
    if !root.last : Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }
}

export component SettingsPage inherits Rectangle {
    in-out property <bool> autostart;
    in-out property <bool> autoupdate_check;
    in-out property <bool> minimize_to_tray;
    in-out property <bool> autoengage;
    in-out property <bool> compact;
    in-out property <string> install_dir;
    in-out property <string> theme; // "dark" | "light" | "system"

    // ── DPI bypass tuning (zapret service.bat filters) ──
    in property <bool> installed;
    in-out property <string> game_filter; // off | all | tcp | udp
    in-out property <string> ipset_mode;  // any | none | loaded | unknown
    in property <int> ipset_lines;
    in property <bool> ipset_busy;
    in property <string> ipset_msg;
    in property <bool> ipset_ok;
    in property <bool> hosts_busy;
    in property <string> hosts_msg;
    in property <bool> hosts_ok;

    callback open_folder_clicked();
    callback theme_changed(string);
    callback game_filter_changed(string);
    callback ipset_mode_changed(string);
    callback update_ipset_clicked();
    callback update_hosts_clicked();

    background: transparent;

    sv := ScrollView {
        viewport-width: sv.visible-width;
        HorizontalLayout {
            VerticalLayout {
                horizontal-stretch: 0;
                width: min(sv.visible-width - 64px, 980px);
                padding-left: 32px;
                padding-top: 28px;
                padding-right: 32px;
                padding-bottom: 60px;
                spacing: 0px;
                alignment: start;

                // page-head
                VerticalLayout {
                    spacing: 2px;
                    padding-bottom: 20px;
                    Text {
                        text: "Settings";
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-22;
                        font-weight: 600;
                        color: ThemePalette.text;
                    }
                    Text {
                        text: "Application preferences, paths and appearance.";
                        font-family: ThemePalette.font-sans;
                        font-size: ThemePalette.fs-13;
                        color: ThemePalette.text-3;
                    }
                }
                Rectangle { height: 1px; background: ThemePalette.divider; }
                Rectangle { height: 16px; }

                // Application
                SettingsGroup {
                    title: "Application";
                    SettingsRow {
                        label: "Start automatically with Windows";
                        hint: "Launch zapret-ui silently on login. Doesn't engage the bypass — only opens the app.";
                        AppSwitch { checked <=> root.autostart; }
                    }
                    SettingsRow {
                        label: "Minimize to system tray on close";
                        hint: "Hide to tray instead of quitting. Right-click the tray icon to fully exit.";
                        AppSwitch { checked <=> root.minimize_to_tray; }
                    }
                    SettingsRow {
                        label: "Engage bypass on app start";
                        hint: "When zapret-ui starts, automatically start the last-used strategy in user mode.";
                        last: true;
                        AppSwitch { checked <=> root.autoengage; }
                    }
                }
                Rectangle { height: 16px; }

                // Updates & paths
                SettingsGroup {
                    title: "Updates & paths";
                    SettingsRow {
                        label: "Check for zapret updates on launch";
                        hint: "Compares your installed core to the latest tag on GitHub.";
                        AppSwitch { checked <=> root.autoupdate_check; }
                    }
                    SettingsRow {
                        label: "Zapret installation folder";
                        hint: "Where the zapret core and host lists live. Managed by the app — open to inspect.";
                        last: true;
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                horizontal-stretch: 0;
                                width: 240px;
                                height: 32px;
                                border-radius: ThemePalette.r-8;
                                border-width: 1px;
                                border-color: ThemePalette.border;
                                background: ThemePalette.bg-2;
                                clip: true;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;
                                    Icon {
                                        source: @image-url("../../assets/icons/folder.svg");
                                        size: 13px;
                                        tint: ThemePalette.text-3;
                                    }
                                    Text {
                                        text: root.install_dir != "" ? root.install_dir : "%APPDATA%\\zapret-ui\\zapret";
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-12;
                                        color: ThemePalette.text-2;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                            AppButton {
                                text: "Open";
                                icon: @image-url("../../assets/icons/external.svg");
                                clicked => { root.open_folder_clicked(); }
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // DPI bypass tuning — the zapret service.bat filters & updaters.
                SettingsGroup {
                    title: "DPI bypass tuning";
                    SettingsRow {
                        label: "Game filter";
                        hint: root.installed
                            ? "Route game traffic (high TCP/UDP ports) through the bypass. Restart the bypass to apply."
                            : "Install zapret first to configure the game filter.";
                        Segmented {
                            enabled: root.installed;
                            selected: root.game_filter;
                            options: [
                                { value: "off", label: "Off" },
                                { value: "all", label: "TCP+UDP" },
                                { value: "tcp", label: "TCP" },
                                { value: "udp", label: "UDP" },
                            ];
                            changed(v) => { root.game_filter = v; root.game_filter_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: "IPSet filter";
                        hint: root.ipset_mode == "loaded"
                            ? "Match the downloaded IP list (\{root.ipset_lines} entries). Restart the bypass to apply."
                            : (root.ipset_mode == "none"
                                ? "IP matching disabled. Restart the bypass to apply."
                                : (root.ipset_mode == "any"
                                    ? "Match any IP (no list). Restart the bypass to apply."
                                    : "How ipset-all.txt is applied by winws."));
                        Segmented {
                            enabled: root.installed && root.ipset_mode != "unknown";
                            selected: root.ipset_mode;
                            options: [
                                { value: "loaded", label: "Loaded" },
                                { value: "none", label: "None" },
                                { value: "any", label: "Any" },
                            ];
                            changed(v) => { root.ipset_mode = v; root.ipset_mode_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: "Update IPSet list";
                        hint: "Download the latest blocked-IP list (ipset-all.txt) from the zapret repository.";
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.ipset_busy ? "Updating…" : "Update";
                                    icon: @image-url("../../assets/icons/download.svg");
                                    enabled: root.installed && !root.ipset_busy;
                                    clicked => { root.update_ipset_clicked(); }
                                }
                            }
                            if root.ipset_msg != "" : Text {
                                text: root.ipset_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.ipset_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                    SettingsRow {
                        label: "Update hosts file";
                        hint: "Compare your system hosts file with the repository's. If outdated, the downloaded copy opens for a manual merge.";
                        last: true;
                        VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: end;
                                AppButton {
                                    text: root.hosts_busy ? "Checking…" : "Check & update";
                                    icon: @image-url("../../assets/icons/refresh.svg");
                                    enabled: !root.hosts_busy;
                                    clicked => { root.update_hosts_clicked(); }
                                }
                            }
                            if root.hosts_msg != "" : Text {
                                text: root.hosts_msg;
                                width: 240px;
                                horizontal-alignment: right;
                                wrap: word-wrap;
                                font-family: ThemePalette.font-sans;
                                font-size: ThemePalette.fs-12;
                                color: root.hosts_ok ? ThemePalette.text-3 : ThemePalette.danger;
                            }
                        }
                    }
                }
                Rectangle { height: 16px; }

                // Appearance
                SettingsGroup {
                    title: "Appearance";
                    SettingsRow {
                        label: "Theme";
                        hint: "Dark by default. Light theme uses a warm off-white background.";
                        Segmented {
                            selected: root.theme;
                            options: [
                                { value: "dark",   label: "Dark",   icon: @image-url("../../assets/icons/moon.svg") },
                                { value: "light",  label: "Light",  icon: @image-url("../../assets/icons/sun.svg") },
                                { value: "system", label: "System", icon: @image-url("../../assets/icons/system.svg") },
                            ];
                            changed(v) => { root.theme = v; root.theme_changed(v); }
                        }
                    }
                    SettingsRow {
                        label: "Compact density";
                        hint: "Tighten paddings and line heights — better on small laptop screens.";
                        last: true;
                        AppSwitch { checked <=> root.compact; }
                    }
                }
            }
            Rectangle { }
        }
    }
}
