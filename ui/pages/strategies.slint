import { ThemePalette, StrategyItem } from "../tokens.slint";
import { I18n } from "../i18n.slint";
import { AppButton } from "../components/button.slint";
import { AppInput } from "../components/input.slint";
import { StarToggle } from "../components/star.slint";
import { ListView } from "std-widgets.slint";

export component StrategiesPage inherits Rectangle {
    in property <[StrategyItem]> strategies_model;
    in property <string> active_strategy_id;
    in property <string> selected_strategy;
    in property <bool> is_busy;
    in-out property <string> query;

    callback picked(StrategyItem);
    callback search_changed(string);
    callback toggle_favorite(string);

    background: transparent;

    pure function pad2(n: int) -> string { return n < 10 ? "0\{n}" : "\{n}"; }

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 0;
            width: min(parent.width - 64px, 980px);
            padding-left: 32px;
            padding-top: 28px;
            padding-right: 32px;
            padding-bottom: 28px;
            spacing: 0px;

            // page-head
            VerticalLayout {
                spacing: 2px;
                padding-bottom: 20px;
                Text {
                    text: I18n.t(I18n.lang, "strategies.title");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-22;
                    font-weight: 600;
                    color: ThemePalette.text;
                }
                Text {
                    text: I18n.t(I18n.lang, "strategies.subtitle");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    color: ThemePalette.text-3;
                }
            }
            Rectangle { height: 1px; background: ThemePalette.divider; }
            Rectangle { height: 18px; }

            // search row
            HorizontalLayout {
                spacing: 12px;
                AppInput {
                    horizontal-stretch: 1;
                    field-height: 36px;
                    icon: @image-url("../../assets/icons/search.svg");
                    placeholder: I18n.t(I18n.lang, "strategies.search_placeholder");
                    text <=> root.query;
                    edited(t) => { root.search_changed(t); }
                    if root.query != "" : AppButton {
                        text: I18n.t(I18n.lang, "common.clear_lower");
                        variant: "ghost";
                        size: "sm";
                        clicked => { root.query = ""; root.search_changed(""); }
                    }
                }
            }

            Rectangle { height: 14px; }

            // list
            Rectangle {
                vertical-stretch: 1;
                border-width: 1px;
                border-color: ThemePalette.border;
                border-radius: ThemePalette.r-12;
                background: ThemePalette.surface;
                clip: true;

                if root.strategies_model.length == 0 : Text {
                    text: I18n.t(I18n.lang, "strategies.no_match_a") + root.query + I18n.t(I18n.lang, "strategies.no_match_b");
                    font-family: ThemePalette.font-sans;
                    font-size: ThemePalette.fs-13;
                    color: ThemePalette.text-3;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                ListView {
                    for item[idx] in root.strategies_model : row := Rectangle {
                        property <bool> is-active: root.active_strategy_id == item.id;
                        property <bool> is-selected: root.selected_strategy == item.id;
                        height: 70px;
                        background: row-ta.has-hover ? ThemePalette.surface-hover : transparent;
                        animate background { duration: 120ms; }

                        Rectangle { y: parent.height - 1px; height: 1px; background: ThemePalette.divider; }

                        row-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.picked(item); }
                        }

                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 16px;

                            // index
                            VerticalLayout {
                                alignment: center;
                                width: 28px;
                                Text {
                                    text: root.pad2(idx + 1);
                                    font-family: ThemePalette.font-mono;
                                    font-size: ThemePalette.fs-11;
                                    color: ThemePalette.text-4;
                                    horizontal-alignment: right;
                                }
                            }

                            // main
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: start;
                                    Text {
                                        text: item.display_name;
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-13;
                                        font-weight: 600;
                                        color: ThemePalette.text;
                                        vertical-alignment: center;
                                    }
                                    if item.alt != "" : Rectangle {
                                        horizontal-stretch: 0;
                                        width: chip-txt.preferred-width + 10px;
                                        height: 17px;
                                        border-radius: ThemePalette.r-4;
                                        background: ThemePalette.surface-2;
                                        chip-txt := Text {
                                            text: item.alt;
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-10;
                                            color: ThemePalette.text-3;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                Text {
                                    text: item.description;
                                    font-family: ThemePalette.font-sans;
                                    font-size: ThemePalette.fs-12;
                                    color: ThemePalette.text-3;
                                    wrap: word-wrap;
                                    overflow: elide;
                                }
                            }

                            // badge
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 0;
                                if row.is-active : Rectangle {
                                    width: run-lay.preferred-width + 16px;
                                    height: 22px;
                                    border-radius: ThemePalette.r-full;
                                    background: ThemePalette.accent-soft;
                                    border-width: 1px;
                                    border-color: ThemePalette.accent-line;
                                    run-lay := HorizontalLayout {
                                        spacing: 5px;
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        alignment: center;
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: ThemePalette.accent; }
                                        }
                                        Text {
                                            text: I18n.t(I18n.lang, "strategies.running_badge");
                                            font-family: ThemePalette.font-mono;
                                            font-size: ThemePalette.fs-11;
                                            color: ThemePalette.accent;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                if row.is-selected && !row.is-active : Rectangle {
                                    width: sel-txt.preferred-width + 16px;
                                    height: 22px;
                                    border-radius: ThemePalette.r-full;
                                    background: ThemePalette.surface-2;
                                    border-width: 1px;
                                    border-color: ThemePalette.border-strong;
                                    sel-txt := Text {
                                        text: I18n.t(I18n.lang, "strategies.selected_badge");
                                        font-family: ThemePalette.font-mono;
                                        font-size: ThemePalette.fs-11;
                                        color: ThemePalette.text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // favorite star
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 0;
                                StarToggle {
                                    favorite: item.favorite;
                                    toggled => { root.toggle_favorite(item.id); }
                                }
                            }

                            // action
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 0;
                                width: 110px;
                                HorizontalLayout {
                                    alignment: end;
                                    if row.is-active : AppButton {
                                        text: I18n.t(I18n.lang, "strategies.active_btn");
                                        size: "sm";
                                        icon: @image-url("../../assets/icons/check.svg");
                                        enabled: false;
                                    }
                                    if row.is-selected && !row.is-active : AppButton {
                                        text: I18n.t(I18n.lang, "strategies.selected_btn");
                                        variant: "primary";
                                        size: "sm";
                                        clicked => { root.picked(item); }
                                    }
                                    if !row.is-active && !row.is-selected : AppButton {
                                        text: I18n.t(I18n.lang, "strategies.select_btn");
                                        size: "sm";
                                        clicked => { root.picked(item); }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        Rectangle { }
    }
}
